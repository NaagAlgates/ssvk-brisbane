{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ssvk",
  "compatibility_date": "2025-05-17",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true
  }
}
