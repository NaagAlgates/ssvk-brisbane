---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';
import ChatWidget from '~/components/ChatWidget.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

interface Props {
  title: string;
  description?: string;
  navVariant?: 'light' | 'dark';
}

const { title, description = 'Sri Selva Vinayakar Koyil — Ganesha Temple, Brisbane. A traditional Hindu temple serving the community of South-East Queensland since 1995.', navVariant = 'dark' } = Astro.props;

let activeNotices: any[] = [];
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  const all = await reader.collections.notices.all();
  const today = new Date().toISOString().slice(0, 10);
  activeNotices = all
    .map((n) => ({ ...n.entry, slug: n.slug }))
    .filter((n) => !n.expiresOn || n.expiresOn >= today)
    .sort((a, b) => {
      const pri = { high: 0, normal: 1, low: 2 };
      return (pri[a.priority as keyof typeof pri] ?? 1) - (pri[b.priority as keyof typeof pri] ?? 1);
    });
} catch {}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FBFAF7" />
    <meta property="og:title" content={`${title} — Sri Selva Vinayakar Koyil, Brisbane`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/temple-birds-view.jpg" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Noto+Sans+Tamil:wght@400;500;600;700&display=swap"
    />
    <title>{title} — Sri Selva Vinayakar Koyil, Brisbane</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HinduTemple",
      "name": "Sri Selva Vinayakar Koyil",
      "alternateName": ["Ganesha Temple Brisbane", "SSVK Brisbane", "ஸ்ரீ செல்வ விநாயகர் கோயில்"],
      "description": "A traditional Hindu Ganesha temple serving the South-East Queensland community since 1995. Located beside the Logan River, 35 km south of Brisbane.",
      "url": "https://ssvk.naaglabs.workers.dev",
      "telephone": "+61755478064",
      "email": "info@ssvk.org.au",
      "foundingDate": "1995-02-05",
      "image": "https://ssvk.naaglabs.workers.dev/images/temple-birds-view.jpg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "4915–4923 Mt Lindesay Highway",
        "addressLocality": "South Maclean",
        "addressRegion": "QLD",
        "postalCode": "4280",
        "addressCountry": "AU"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -27.785,
        "longitude": 152.982
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "07:30",
          "closes": "12:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "17:00",
          "closes": "20:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday","Sunday"],
          "opens": "07:30",
          "closes": "13:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday","Sunday"],
          "opens": "17:00",
          "closes": "20:30"
        }
      ],
      "sameAs": [
        "https://www.facebook.com/profile.php?id=100064840352331",
        "https://www.youtube.com/channel/UCk9J8Hm8iWsLhce9tkrP3gw"
      ]
    })} />
  </head>
  <body>
    <Nav variant={navVariant} />
    {activeNotices.length > 0 && (
      <div class="notice-banners">
        {activeNotices.map((n) => {
          const isHigh = n.priority === 'high';
          const isLow = n.priority === 'low';
          const bg = isHigh ? 'rgba(220,38,38,0.08)' : isLow ? 'rgba(0,0,0,0.04)' : 'rgba(201,115,14,0.08)';
          const border = isHigh ? '#dc2626' : isLow ? 'var(--color-rule)' : 'var(--color-saffron)';
          const color = isHigh ? '#dc2626' : isLow ? 'var(--color-ink-soft)' : 'var(--color-saffron)';
          const icon = isHigh ? '⚠' : isLow ? 'ℹ' : '📢';
          return (
            <div style={`background:${bg}; border-bottom: 1px solid ${border};`}>
              <div class="container-tight py-3 flex items-center gap-3 text-sm">
                <span style={`color:${color}; font-size:1rem;`}>{icon}</span>
                <p style={`color:${color}; font-weight:500;`}>{n.title}</p>
              </div>
            </div>
          );
        })}
      </div>
    )}
    <main>
      <slot />
    </main>
    <Footer />
    <ChatWidget />
  </body>
</html>
