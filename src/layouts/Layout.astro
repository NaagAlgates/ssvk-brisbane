---
import '~/styles/global.css';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sri Selva Vinayakar Koyil — Ganesha Temple, Brisbane. A traditional Hindu temple serving the Tamil community of South-East Queensland since 1995.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FBFAF7" />
    <meta property="og:title" content={`${title} — Sri Selva Vinayakar Koyil, Brisbane`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/temple-entrance-up.jpg" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Noto+Sans+Tamil:wght@400;500;600;700&display=swap"
    />
    <title>{title} — Sri Selva Vinayakar Koyil, Brisbane</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
