---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let site: any = null;
let hours: any = null;
let canteen: any = null;
let menu: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  site = await reader.singletons.siteConfig.read();
  hours = await reader.singletons.openingHours.read();
  canteen = await reader.singletons.canteenStatus.read();
  menu = await reader.collections.canteenMenu.all();
} catch {}

const availableMenu = menu
  .map((m) => ({ ...m.entry, slug: m.slug }))
  .filter((m) => m.available);

const menuByCategory: Record<string, any[]> = {};
for (const item of availableMenu) {
  const cat = item.category || 'snacks';
  if (!menuByCategory[cat]) menuByCategory[cat] = [];
  menuByCategory[cat].push(item);
}

const addr = site ?? {
  templeAddressLine1: '4915–4923 Mt Lindesay Highway',
  suburb: 'South Maclean',
  state: 'QLD',
  postcode: '4280',
  country: 'Australia',
  phonePrimary: '+61 7 5547 8064',
  emailGeneral: 'info@ssvk.org.au',
  googleMapsUrl: 'https://www.google.com/maps/search/?api=1&query=Sri+Selva+Vinayakar+Koyil+South+Maclean',
};
export const prerender = true;
---
<Layout title="Visit">
  {/* Quiet hero */}
  <section class="pt-32 md:pt-44 pb-12">
    <div class="container-tight max-w-4xl">
      <p class="eyebrow mb-6">Visit Us</p>
      <h1 class="text-[var(--color-ink)] mb-4 text-balance" style="font-weight: 400;">Plan your visit</h1>
      <p lang="ta" class="tamil-display mb-10">எங்கள் கோயிலை தரிசியுங்கள்</p>
    </div>
  </section>

  <section class="container-tight">
    <div class="aspect-[21/9] photo-frame">
      <img src="/images/temple-side.jpg" alt="Side view of the temple" loading="eager" />
    </div>
  </section>

  {/* ADDRESS + HOURS — bento grid, quiet register */}
  <section class="py-24 md:py-32">
    <div class="container-tight grid lg:grid-cols-12 gap-6">
      <div class="lg:col-span-7 card card-hover">
        <p class="eyebrow mb-4">Where to find us</p>
        <p class="text-2xl md:text-3xl font-[var(--font-display)] text-[var(--color-ink)] mb-2 leading-snug">
          {addr.templeAddressLine1}
        </p>
        <p class="text-[var(--color-ink-soft)] text-lg mb-6">
          {addr.suburb} {addr.state} {addr.postcode} · {addr.country}
        </p>
        <a href={addr.googleMapsUrl} target="_blank" rel="noopener" class="btn btn-primary mb-8">
          Open in Google Maps ↗
        </a>
        <div class="border-t border-[var(--color-rule)] pt-6 grid sm:grid-cols-2 gap-6">
          <div>
            <p class="eyebrow mb-2">Phone</p>
            <a href={`tel:${addr.phonePrimary}`} class="text-[var(--color-ink)] hover:text-[var(--color-saffron)] text-lg">
              {addr.phonePrimary}
            </a>
          </div>
          <div>
            <p class="eyebrow mb-2">Email</p>
            <a href={`mailto:${addr.emailGeneral}`} class="text-[var(--color-ink)] hover:text-[var(--color-saffron)] text-lg">
              {addr.emailGeneral}
            </a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 card card-hover">
        <p class="eyebrow mb-4">Opening Hours</p>
        <div class="space-y-5 mb-6">
          <div>
            <p class="text-[var(--color-ink)] font-semibold mb-1">Monday – Friday</p>
            <p class="text-[var(--color-ink-soft)]">{hours?.weekdayMorningOpen ?? '7:30am'} – {hours?.weekdayMorningClose ?? '12:00pm'}</p>
            <p class="text-[var(--color-ink-soft)]">{hours?.weekdayEveningOpen ?? '5:00pm'} – {hours?.weekdayEveningClose ?? '8:30pm'}</p>
          </div>
          <div>
            <p class="text-[var(--color-ink)] font-semibold mb-1">Saturday – Sunday</p>
            <p class="text-[var(--color-ink-soft)]">{hours?.weekendMorningOpen ?? '7:30am'} – {hours?.weekendMorningClose ?? '1:00pm'}</p>
            <p class="text-[var(--color-ink-soft)]">{hours?.weekendEveningOpen ?? '5:00pm'} – {hours?.weekendEveningClose ?? '8:30pm'}</p>
          </div>
        </div>
        <div class="border-t border-[var(--color-rule)] pt-4">
          <p class="eyebrow mb-2">Pooja Times</p>
          <p class="text-[var(--color-saffron)] text-lg font-medium">{hours?.poojaMorning ?? '9:00am – 9:30am'}</p>
          <p class="text-[var(--color-saffron)] text-lg font-medium">{hours?.poojaEvening ?? '7:00pm – 7:30pm'}</p>
        </div>
      </div>
    </div>
  </section>

  {/* CANTEEN — quiet register with live status accent */}
  <section class="py-24 md:py-32 bg-[var(--color-paper-soft)]">
    <div class="container-tight">
      <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
        <div>
          <p class="eyebrow mb-3">Temple Canteen</p>
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Kamadhenu</h2>
        </div>
        <div class="flex items-center gap-3 px-4 py-2 bg-[var(--color-paper)] border border-[var(--color-rule)]">
          <span class={`w-2.5 h-2.5 rounded-full ${canteen?.isOpen ? 'bg-[var(--color-teal)] animate-pulse' : 'bg-[var(--color-saffron)]'}`}></span>
          <span class="text-[var(--color-ink)] font-medium">
            {canteen?.isOpen ? `Open · ${canteen.todayHoursOpen} – ${canteen.todayHoursClose}` : 'Closed today'}
          </span>
        </div>
      </div>

      {canteen?.specialNotice && (
        <p class="card text-[var(--color-saffron)] italic mb-8">{canteen.specialNotice}</p>
      )}

      {Object.keys(menuByCategory).length > 0 ? (
        <div class="space-y-12">
          {Object.entries(menuByCategory).map(([category, items]) => (
            <div>
              <h3 class="capitalize text-[var(--color-ink)] mb-6 pb-3 border-b border-[var(--color-rule)]">
                {category}
              </h3>
              <div class="grid sm:grid-cols-2 gap-4">
                {items.map((item) => (
                  <div class="flex items-baseline justify-between gap-4 py-3 border-b border-[var(--color-rule)]">
                    <div>
                      <p class="text-[var(--color-ink)] font-medium">{item.name}</p>
                      {item.nameTamil && <p lang="ta" class="text-sm text-[var(--color-ink-soft)] tamil-body">{item.nameTamil}</p>}
                      {item.description && <p class="text-sm text-[var(--color-ink-mute)] mt-1">{item.description}</p>}
                    </div>
                    <p class="text-xl font-[var(--font-display)] text-[var(--color-saffron)] whitespace-nowrap" style="font-weight: 500;">
                      ${item.price?.toFixed(2)}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="card text-[var(--color-ink-soft)] italic">
          Menu will appear here once added via the admin panel.
        </p>
      )}
    </div>
  </section>
</Layout>
