  {/* LIFE EVENTS & OTHER FUNCTIONS */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Life Events</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Other Functions</h2>
