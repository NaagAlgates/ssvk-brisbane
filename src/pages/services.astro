          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Outside the Temple</h3>
            <p class="text-sm text-[var(--color-ink-soft)] mb-4">
