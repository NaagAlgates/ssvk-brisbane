                { name: 'Grahapravesam — Ganapathy Homam only', note: 'Includes Ganapathy Homam, Punyaavachanam & Pada Poojai', price: '$201.00' },
                { name: 'Grahapravesam — Basic Ceremony', note: 'Ganapathy Poojai, Punyavachanam & Pada Poojai', price: '$151.00' },
                { name: 'Foundation Ceremony', note: '', price: '$151.00' },
                { name: 'Punyaha Vaachanam (Thudakku Kalivu)', note: '', price: '$151.00' },
                { name: 'Thivasam', note: '', price: '$151.00' },
                { name: 'Chabindikaranam', note: '31st day ceremony after death', price: '$151.00' },
                { name: 'Upanayanam', note: 'Sacred thread ceremony. Sponsor receives one prasadam.', price: '$201.00' },
