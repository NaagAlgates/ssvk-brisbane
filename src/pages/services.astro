    </div>
    <div class="container-tight relative z-10 pb-16 md:pb-24">
      <p class="eyebrow mb-6" style="color: var(--color-saffron);">Services & Festivals</p>
      <h1 class="mb-4 text-balance" style="font-weight: 400; color: #fff;">Pooja, Archana & the Sacred Year</h1>
      <p lang="ta" class="tamil-display mb-2" style="color: rgba(255,255,255,0.75);">பூஜை மற்றும் திருவிழாக்கள்</p>
    </div>
  </section>

  {/* POOJA SERVICES — quiet editorial register */}
  <section class="py-24 md:py-32">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Sacred Rites</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Pooja & Archana</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">பூஜை & அர்ச்சனை</p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed">
            Personal poojas and archanas can be performed by the temple priests. Book in
            advance for major rites such as Abishekam and Homam.
          </p>
        </div>
        <div class="lg:col-span-8">
          {allServices.length > 0 ? (
            <div class="divide-y divide-[var(--color-rule)]">
              {allServices.map((s) => (
                <div class="py-6 grid grid-cols-12 gap-4 items-baseline">
                  <div class="col-span-7">
                    <h3 class="text-2xl text-[var(--color-ink)] font-[var(--font-display)] mb-1" style="font-weight: 500;">
                      {s.name}
                    </h3>
                    {s.nameTamil && <p lang="ta" class="text-[var(--color-saffron)] tamil-body !text-lg">{s.nameTamil}</p>}
                  </div>
                  <div class="col-span-2 text-[var(--color-ink-mute)] text-sm">
                    {s.durationMinutes ? `${s.durationMinutes} min` : ''}
