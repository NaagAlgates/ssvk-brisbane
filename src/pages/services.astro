---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let services: any[] = [];
let festivals: any[] = [];
let events: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  services = await reader.collections.poojaServices.all();
  festivals = await reader.collections.festivals.all();
  events = await reader.collections.events.all();
} catch {}

const today = new Date();
const upcomingFestivals = festivals
  .map((f) => ({ ...f.entry, slug: f.slug }))
  .filter((f) => new Date(f.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const allServices = services.map((s) => ({ ...s.entry, slug: s.slug }));

const allEvents = events
  .map((e) => ({ ...e.entry, slug: e.slug }))
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const WEEKDAYS = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
export const prerender = true;
---
<Layout title="Services & Festivals">
  {/* Quiet hero */}
  <section class="pt-32 md:pt-44 pb-12">
    <div class="container-tight max-w-4xl">
      <p class="eyebrow mb-6">Services & Festivals</p>
      <h1 class="text-[var(--color-ink)] mb-4 text-balance" style="font-weight: 400;">Pooja, Archana & the Sacred Year</h1>
      <p lang="ta" class="tamil-display mb-10">பூஜை மற்றும் திருவிழாக்கள்</p>
    </div>
  </section>

  {/* Photo break — chariot detail */}
  <section class="container-tight">
    <div class="aspect-[21/9] photo-frame">
      <img src="/images/chariot-detail.jpg" alt="Close-up of the temple chariot with priest and deity" loading="eager" />
    </div>
  </section>

  {/* POOJA SERVICES — quiet editorial register */}
  <section class="py-24 md:py-32">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Sacred Rites</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Pooja & Archana</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">பூஜை & அர்ச்சனை</p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed">
            Personal poojas and archanas can be performed by the temple priests. Book in
            advance for major rites such as Abishekam and Homam.
          </p>
        </div>
        <div class="lg:col-span-8">
          {allServices.length > 0 ? (
            <div class="divide-y divide-[var(--color-rule)]">
              {allServices.map((s) => (
                <div class="py-6 grid grid-cols-12 gap-4 items-baseline">
                  <div class="col-span-7">
                    <h3 class="text-2xl text-[var(--color-ink)] font-[var(--font-display)] mb-1" style="font-weight: 500;">
                      {s.name}
                    </h3>
                    {s.nameTamil && <p lang="ta" class="text-[var(--color-saffron)] tamil-body !text-lg">{s.nameTamil}</p>}
                  </div>
                  <div class="col-span-2 text-[var(--color-ink-mute)] text-sm">
                    {s.durationMinutes ? `${s.durationMinutes} min` : ''}
                  </div>
                  <div class="col-span-3 text-right">
                    <p class="text-3xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">
                      ${s.priceAud?.toFixed(0)}
                    </p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="card text-[var(--color-ink-soft)] italic">
              Pooja & Archana price list will appear here once added via the admin panel.
            </p>
          )}
          <p class="mt-8 text-sm text-[var(--color-ink-soft)]">
            To book a service, please call <a href="tel:+61755478064" class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)]">07 5547 8064</a> or
            email <a href="mailto:info@ssvk.org.au" class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)]">info@ssvk.org.au</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ARCHANA GUIDE */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">How to Worship</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Archana Guide</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">அர்ச்சனை வழிகாட்டி</p>
        </div>
        <div class="lg:col-span-8 prose-content text-[var(--color-ink-soft)] text-lg leading-relaxed space-y-6">
          <p>
            Archana is the devotional offering of flower petals or leaves to the deity, accompanied by the chanting of the deity's names. At SSVK, Archana is performed by the temple priest on behalf of devotees.
          </p>
          <p>
            To request an Archana, collect an Archana ticket from the temple office and provide your family name (gothram). The priest will chant 108 names of Lord Vinayakar while offering flowers in your name.
          </p>
          <p>
            Archana is available during all regular temple hours. Special Archanas for birthdays, weddings, and significant occasions can be arranged in advance by contacting the temple.
          </p>
          <p class="text-sm text-[var(--color-ink-mute)] border-l-2 border-[var(--color-rule)] pl-4">
            For the full Archana information guide, please ask at the temple office or contact us.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* TEMPLE FESTIVAL PROCEDURE */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Festival Observance</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Festival Procedures</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">திருவிழா நடைமுறை</p>
        </div>
        <div class="lg:col-span-8 prose-content text-[var(--color-ink-soft)] text-lg leading-relaxed space-y-6">
          <p>
            SSVK temple festivals follow traditional Agamic procedures as observed in South Indian Saiva temples. Each festival involves specific rituals performed by the temple Kurukkal (priest) in accordance with the <em>Agama Sastra</em>.
          </p>
          <p>
            Devotees are welcome to participate in all public festival events. Major festivals such as Vinayakar Chaturthi, Panguni Uthiram, and the annual Kumbabishekam anniversary involve multiple days of rituals, processions, and community gatherings.
          </p>
          <p>
            Sponsorship opportunities are available for festival events. Sponsors are honoured during the proceedings and receive a formal receipt for tax purposes. Please contact the temple committee to discuss sponsorship arrangements.
          </p>
          <p class="text-sm text-[var(--color-ink-mute)] border-l-2 border-[var(--color-rule)] pl-4">
            The full Temple Festival Procedure document is available at the temple office.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* FESTIVAL CALENDAR — VIBRANT REGISTER */}
  <section class="festival-section py-32">
    <div class="container-tight">
      <div class="text-center mb-16">
        <p class="eyebrow mb-4" style="color: var(--color-saffron);">Sacred Year</p>
        <h2 class="text-[var(--color-ink)] mb-3" style="font-weight: 400;">Festival Calendar</h2>
        <p lang="ta" class="tamil-display !text-[var(--color-teal)]">திருவிழாக்கள்</p>
      </div>
      {upcomingFestivals.length > 0 ? (
        <ol class="space-y-4 max-w-4xl mx-auto">
          {upcomingFestivals.map((f, i) => {
            const date = new Date(f.date);
            const accentColor = i % 3 === 0 ? 'var(--color-saffron)' : i % 3 === 1 ? 'var(--color-teal)' : 'var(--color-saffron)';
            return (
              <li class="festival-card card-hover grid md:grid-cols-12 gap-6 items-center" style={`border-left-color: ${accentColor};`}>
                <div class="md:col-span-2 text-center md:border-r md:border-[var(--color-rule)] md:pr-6">
                  <p class="text-5xl font-[var(--font-display)] font-light leading-none" style={`color: ${accentColor};`}>
                    {date.getDate()}
                  </p>
                  <p class="eyebrow mt-2" style={`color: ${accentColor};`}>
                    {date.toLocaleDateString('en-AU', { month: 'short' })} {date.getFullYear()}
                  </p>
                </div>
                <div class="md:col-span-7">
                  <h3 class="text-2xl text-[var(--color-ink)] mb-1" style="font-weight: 500;">{f.name}</h3>
                  {f.nameTamil && <p lang="ta" class="text-[var(--color-ink-soft)] tamil-body !text-lg">{f.nameTamil}</p>}
                  {f.time && <p class="text-[var(--color-ink-mute)] text-sm mt-3">{f.time}</p>}
                </div>
                <div class="md:col-span-3 md:text-right">
                  {f.type === 'major' && (
                    <span class="inline-block text-[0.65rem] uppercase tracking-widest px-3 py-1" style={`color: ${accentColor}; border: 1px solid ${accentColor};`}>
                      Major
                    </span>
                  )}
                  <p class="text-sm text-[var(--color-ink-mute)] mt-2">
                    {date.toLocaleDateString('en-AU', { weekday: 'long' })}
                  </p>
                </div>
              </li>
            );
          })}
        </ol>
      ) : (
        <p class="card text-center text-[var(--color-ink-soft)] italic max-w-xl mx-auto">
          Festival calendar will appear here once added via the admin panel.
        </p>
      )}
    </div>
  </section>

  {/* MONTHLY PROGRAMME */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Monthly Observances</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Monthly Programme</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">மாத நிகழ்ச்சிகள்</p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed text-sm">
            Regular observances, abishekams, and special poojas as listed in the monthly newsletter.
          </p>
        </div>
        <div class="lg:col-span-8">
          {allEvents.length > 0 ? (
            <div class="space-y-0">
              {allEvents.map((ev, i) => {
                const evDate = new Date(ev.date);
                const dayNum = evDate.getDate();
                const weekday = WEEKDAYS[evDate.getDay()];
                const month = MONTHS[evDate.getMonth()].substring(0, 3);
                const isMajor = ev.type === 'major';
                const program: { time: string; activity: string }[] = ev.program ?? [];
                return (
                  <div class={`grid grid-cols-12 gap-x-6 gap-y-1 py-5 ${i > 0 ? 'border-t border-[var(--color-rule)]' : ''}`}>
                    <div class="col-span-2 pt-0.5">
                      <p class="text-3xl leading-none font-light" style={isMajor ? 'color: var(--color-saffron);' : 'color: var(--color-ink);'}>
                        {dayNum}
                      </p>
                      <p class="text-[0.65rem] tracking-widest uppercase text-[var(--color-ink-mute)] mt-1">
                        {weekday.substring(0, 3)} {month}
                      </p>
                    </div>
                    <div class="col-span-10">
                      <div class="flex items-baseline gap-3 mb-2">
                        <h3 class="text-lg text-[var(--color-ink)]" style="font-weight: 500;">{ev.title}</h3>
                        {isMajor && (
                          <span class="text-[0.6rem] tracking-widest uppercase px-2 py-0.5 border border-[var(--color-saffron)] text-[var(--color-saffron)]">
                            Major
                          </span>
                        )}
                      </div>
                      {ev.titleTamil && (
                        <p lang="ta" class="text-sm text-[var(--color-saffron)] tamil-body mb-2">{ev.titleTamil}</p>
                      )}
                      {program.length > 0 && (
                        <div class="space-y-1 mt-2">
                          {program.map((item) => (
                            <div class="flex gap-4 text-sm">
                              <span class="tabular-nums shrink-0 w-16" style="color: var(--color-saffron);">{item.time}</span>
                              <span class="text-[var(--color-ink-soft)]">{item.activity}</span>
                            </div>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          ) : (
            <p class="card text-[var(--color-ink-soft)] italic">
              Monthly programme will appear here once added via the admin panel.
            </p>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>
