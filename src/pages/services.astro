          </div>

          {/* Sponsored Abishekams */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Sponsored Abishekams</h3>
            <div class="divide-y divide-[var(--color-rule)]">
              {[
                { name: 'Paal Abishekam', note: 'Abishekam with milk. Sponsor receives one prasadam.', price: 51 },
