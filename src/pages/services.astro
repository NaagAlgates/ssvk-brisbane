---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let services: any[] = [];
let docs: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  services = await reader.collections.poojaServices.all();
  docs = await reader.collections.libraryDocuments.all();
} catch {}

const allServices = services.map((s) => ({ ...s.entry, slug: s.slug }));
const allDocs = docs.map((d) => ({ ...d.entry, slug: d.slug }));

const koyilMani = allDocs
  .filter((d) => d.category === 'koyil-mani')
  .sort((a, b) => (b.sortOrder ?? 0) - (a.sortOrder ?? 0));

const worshipSeries = allDocs
  .filter((d) => d.category === 'worship-series')
  .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));

export const prerender = true;
---
<Layout title="Services & Festivals" description="Book pooja services at SSVK Ganesha Temple Brisbane — Archana ($11), Abishekam ($75), Ganapathy Homam ($251). View our annual Hindu festival calendar for South-East Queensland.">

  {/* Full-bleed cinematic hero */}
  <section class="relative min-h-[75vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/ssvk-entrance.jpg"
