  {/* Photo break: wide temple */}
  <section class="relative h-[50vh] overflow-hidden">
    <img src="/images/temple-wide.jpg" alt="Sri Selva Vinayakar Temple" class="w-full h-full object-cover object-center" loading="lazy" />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.62);"></div>
    <div class="absolute inset-0 flex items-center justify-center text-center px-6">
      <div>
        <p class="eyebrow mb-4" style="color: var(--color-saffron);">Knowledge & Devotion</p>
        <p class="text-white text-2xl md:text-3xl font-[var(--font-display)]" style="font-weight: 300;">Temple Library & Publications</p>
        <p lang="ta" class="mt-3 tamil-display !text-xl" style="color: rgba(255,255,255,0.65);">கோயில் நூலகம்</p>
      </div>
    </div>
  </section>

  {/* LIBRARY */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight max-w-4xl space-y-20">

      {/* Koyil Mani Magazine */}
      <div>
        <div class="border-t border-[var(--color-rule)] pt-10 mb-10">
          <p class="eyebrow mb-3">Temple Magazine</p>
          <h2 class="text-[var(--color-ink)] text-3xl" style="font-weight: 400;">Koyil Mani</h2>
          <p lang="ta" class="tamil-display !text-2xl mt-2">கோயில் மணி</p>
        </div>
        {koyilMani.length > 0 ? (
          <div class="divide-y divide-[var(--color-rule)]">
            {koyilMani.map((d) => (
              <div class="py-5 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-lg text-[var(--color-ink)] font-medium">{d.title}</h3>
                  {d.description && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{d.description}</p>}
                  {d.date && (
                    <p class="text-xs text-[var(--color-ink-mute)] mt-1">
                      {new Date(d.date).toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}
                    </p>
                  )}
                </div>
                <a
                  href={d.pdfUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-secondary !py-2 !px-4 !min-h-[36px] text-xs whitespace-nowrap flex-shrink-0"
                >
                  Download PDF
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="card text-[var(--color-ink-soft)] italic">No Koyil Mani issues published yet.</p>
        )}
      </div>

      {/* Temple Worship Series */}
      <div>
        <div class="border-t border-[var(--color-rule)] pt-10 mb-10">
          <p class="eyebrow mb-3">Worship Guides</p>
          <h2 class="text-[var(--color-ink)] text-3xl" style="font-weight: 400;">Temple Worship Series</h2>
          <p class="text-[var(--color-ink-soft)] mt-3 text-base leading-relaxed max-w-xl">
            A series of worship guides by Sri Santhan Kurukkal, covering temple rituals and devotional practices.
          </p>
        </div>
        {worshipSeries.length > 0 ? (
          <div class="divide-y divide-[var(--color-rule)]">
            {worshipSeries.map((d) => (
              <div class="py-5 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-lg text-[var(--color-ink)] font-medium">{d.title}</h3>
                  {d.description && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{d.description}</p>}
                </div>
                <a
                  href={d.pdfUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-secondary !py-2 !px-4 !min-h-[36px] text-xs whitespace-nowrap flex-shrink-0"
                >
                  Download PDF
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="card text-[var(--color-ink-soft)] italic">No worship guides published yet.</p>
        )}
      </div>

    </div>
  </section>
</Layout>
