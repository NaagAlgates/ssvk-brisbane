  {/* Photo break: temple moody */}
  <section class="relative h-[50vh] overflow-hidden">
    <img src="/images/temple-moody.jpg" alt="Sri Selva Vinayakar Temple" class="w-full h-full object-cover object-center" loading="lazy" />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.62);"></div>
