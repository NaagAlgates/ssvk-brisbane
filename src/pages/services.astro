---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let services: any[] = [];
let festivals: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  services = await reader.collections.poojaServices.all();
  festivals = await reader.collections.festivals.all();
} catch {}

const today = new Date();
const upcomingFestivals = festivals
  .map((f) => ({ ...f.entry, slug: f.slug }))
  .filter((f) => new Date(f.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const allServices = services.map((s) => ({ ...s.entry, slug: s.slug }));
---
<Layout title="Services & Festivals">
  {/* HERO — chariot detail */}
  <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
    <img
      src="/images/chariot-detail.jpg"
      alt="Close-up of the temple chariot with priest and deity"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="hero-image-overlay"></div>
    <div class="absolute inset-0 flex items-end">
      <div class="container-tight pb-12 md:pb-20">
        <p class="eyebrow mb-4">Services & Festivals</p>
        <h1 class="text-[var(--color-cream-50)]" style="font-weight: 400;">Pooja, Archana & the Sacred Year</h1>
      </div>
    </div>
  </section>

  {/* POOJA SERVICES */}
  <section class="py-24 md:py-32">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-6">Sacred Rites</p>
          <h2 class="text-[var(--color-cream-50)] mb-4" style="font-weight: 400;">Pooja & Archana</h2>
          <p lang="ta" class="display-tamil mb-6">பூஜை & அர்ச்சனை</p>
          <p class="text-[var(--color-cream-200)] leading-relaxed">
            Personal poojas and archanas can be performed by the temple priests. Book in
            advance for major rites such as Abishekam and Homam.
          </p>
        </div>
        <div class="lg:col-span-8">
          {allServices.length > 0 ? (
            <div class="divide-y divide-[var(--color-ink-600)]">
              {allServices.map((s) => (
                <div class="py-6 grid grid-cols-12 gap-4 items-baseline">
                  <div class="col-span-7">
                    <h3 class="text-2xl text-[var(--color-cream-50)] font-[var(--font-display)] mb-1" style="font-weight: 500;">
                      {s.name}
                    </h3>
                    {s.nameTamil && <p lang="ta" class="text-[var(--color-cream-200)] font-[var(--font-tamil-display)] text-lg">{s.nameTamil}</p>}
                  </div>
                  <div class="col-span-2 text-[var(--color-cream-300)] text-sm">
                    {s.durationMinutes ? `${s.durationMinutes} min` : ''}
                  </div>
                  <div class="col-span-3 text-right">
                    <p class="text-3xl font-[var(--font-display)] text-[var(--color-gold-400)]" style="font-weight: 500;">
                      ${s.priceAud?.toFixed(0)}
                    </p>
                    <p class="eyebrow !text-[0.6rem] !text-[var(--color-cream-300)]">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="card text-[var(--color-cream-200)] italic">
              Pooja & Archana price list will appear here once added via the admin panel.
            </p>
          )}
          <p class="mt-8 text-sm text-[var(--color-cream-300)]">
            To book a service, please call <a href="tel:+61755478064" class="text-[var(--color-gold-400)] hover:text-[var(--color-gold-300)]">07 5547 8064</a> or
            email <a href="mailto:info@ssvk.org.au" class="text-[var(--color-gold-400)] hover:text-[var(--color-gold-300)]">info@ssvk.org.au</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* FESTIVAL CALENDAR — alternating cards with photography */}
  <section class="py-24 md:py-32 bg-[var(--color-ink-950)]">
    <div class="container-tight">
      <div class="text-center mb-16">
        <p class="eyebrow mb-4">Sacred Year</p>
        <h2 class="text-[var(--color-cream-50)] mb-3" style="font-weight: 400;">Festival Calendar</h2>
        <p lang="ta" class="display-tamil">திருவிழாக்கள்</p>
        <span class="gold-rule gold-rule-center mt-6" aria-hidden="true"></span>
      </div>
      {upcomingFestivals.length > 0 ? (
        <ol class="space-y-6 max-w-4xl mx-auto">
          {upcomingFestivals.map((f, i) => {
            const date = new Date(f.date);
            return (
              <li class="card card-elevated grid md:grid-cols-12 gap-6 items-center">
                <div class="md:col-span-2 text-center md:border-r md:border-[var(--color-ink-600)] md:pr-6">
                  <p class="text-5xl font-[var(--font-display)] text-[var(--color-gold-400)] font-light leading-none">
                    {date.getDate()}
                  </p>
                  <p class="eyebrow mt-2">
                    {date.toLocaleDateString('en-AU', { month: 'short' })} {date.getFullYear()}
                  </p>
                </div>
                <div class="md:col-span-7">
                  <h3 class="text-2xl text-[var(--color-cream-50)] mb-1" style="font-weight: 500;">{f.name}</h3>
                  {f.nameTamil && <p lang="ta" class="text-[var(--color-cream-200)] font-[var(--font-tamil-display)] text-lg">{f.nameTamil}</p>}
                  {f.time && <p class="text-[var(--color-cream-300)] text-sm mt-3">⏱  {f.time}</p>}
                </div>
                <div class="md:col-span-3 md:text-right">
                  {f.type === 'major' && (
                    <span class="inline-block text-[0.65rem] uppercase tracking-widest border border-[var(--color-gold-500)] text-[var(--color-gold-400)] px-3 py-1">
                      Major
                    </span>
                  )}
                  <p class="text-sm text-[var(--color-cream-300)] mt-2">
                    {date.toLocaleDateString('en-AU', { weekday: 'long' })}
                  </p>
                </div>
              </li>
            );
          })}
        </ol>
      ) : (
        <p class="card text-center text-[var(--color-cream-200)] italic max-w-xl mx-auto">
          Festival calendar will appear here once added via the admin panel.
        </p>
      )}
    </div>
  </section>
</Layout>
