                { name: 'Nava Kalasa Abishekam', note: 'On a regular day. Sponsor receives one prasadam.', price: 151 },
                { name: 'Nava Kalasa Abishekam (Special Days)', note: 'During special festival days. Sponsor receives one prasadam.', price: 201 },
                { name: 'Sankadahara Chathurthi Abishekam', note: 'Sponsor receives one prasadam.', price: 201 },
                { name: 'Monthly Chathurthi Abishekam', note: 'Circumambulation of inner sanctum. Excludes Aavani Chathurthi. Sponsor receives one prasadam.', price: 251 },
                { name: 'Navagraha Homam & Abishekam', note: 'Sponsor receives one prasadam.', price: 251 },
                { name: 'Sangabishekam', note: '108 conch. Sponsor receives two prasadams.', price: 501 },
              ].map((item) => (
                <div class="grid grid-cols-12 gap-4 items-baseline py-4">
                  <div class="col-span-8">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>
                  </div>
                  <div class="col-span-4 text-right">
                    <p class="text-2xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">${item.price}.00</p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
