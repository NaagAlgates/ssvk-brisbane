    </div>
  </section>

  {/* Photo break: gopuram */}
  <section class="relative h-[50vh] overflow-hidden">
    <img src="/images/temple-gopuram-up.jpg" alt="Temple gopuram" class="w-full h-full object-cover object-top" loading="lazy" />
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.62);"></div>
    <div class="absolute inset-0 flex items-center justify-center text-center px-6">
      <div>
        <p class="eyebrow mb-4" style="color: var(--color-saffron);">Milestones of Life</p>
