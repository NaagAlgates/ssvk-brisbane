---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let services: any[] = [];
let docs: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  services = await reader.collections.poojaServices.all();
  docs = await reader.collections.libraryDocuments.all();
} catch {}

const allServices = services.map((s) => ({ ...s.entry, slug: s.slug }));
const allDocs = docs.map((d) => ({ ...d.entry, slug: d.slug }));

const koyilMani = allDocs
  .filter((d) => d.category === 'koyil-mani')
  .sort((a, b) => (b.sortOrder ?? 0) - (a.sortOrder ?? 0));

const worshipSeries = allDocs
  .filter((d) => d.category === 'worship-series')
  .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));

export const prerender = true;
---
<Layout title="Services & Festivals">
  {/* Quiet hero */}
  <section class="pt-32 md:pt-44 pb-12">
    <div class="container-tight max-w-4xl">
      <p class="eyebrow mb-6">Services & Festivals</p>
      <h1 class="text-[var(--color-ink)] mb-4 text-balance" style="font-weight: 400;">Pooja, Archana & the Sacred Year</h1>
      <p lang="ta" class="tamil-display mb-10">பூஜை மற்றும் திருவிழாக்கள்</p>
    </div>
  </section>

  {/* Photo break — chariot detail */}
  <section class="container-tight">
    <div class="aspect-[21/9] photo-frame">
      <img src="/images/chariot-detail.jpg" alt="Close-up of the temple chariot with priest and deity" loading="eager" />
    </div>
  </section>

  {/* POOJA SERVICES — quiet editorial register */}
  <section class="py-24 md:py-32">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Sacred Rites</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Pooja & Archana</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">பூஜை & அர்ச்சனை</p>
          <p class="text-[var(--color-ink-soft)] leading-relaxed">
            Personal poojas and archanas can be performed by the temple priests. Book in
            advance for major rites such as Abishekam and Homam.
          </p>
        </div>
        <div class="lg:col-span-8">
          {allServices.length > 0 ? (
            <div class="divide-y divide-[var(--color-rule)]">
              {allServices.map((s) => (
                <div class="py-6 grid grid-cols-12 gap-4 items-baseline">
                  <div class="col-span-7">
                    <h3 class="text-2xl text-[var(--color-ink)] font-[var(--font-display)] mb-1" style="font-weight: 500;">
                      {s.name}
                    </h3>
                    {s.nameTamil && <p lang="ta" class="text-[var(--color-saffron)] tamil-body !text-lg">{s.nameTamil}</p>}
                  </div>
                  <div class="col-span-2 text-[var(--color-ink-mute)] text-sm">
                    {s.durationMinutes ? `${s.durationMinutes} min` : ''}
                  </div>
                  <div class="col-span-3 text-right">
                    <p class="text-3xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">
                      ${s.priceAud?.toFixed(0)}
                    </p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="card text-[var(--color-ink-soft)] italic">
              Pooja & Archana price list will appear here once added via the admin panel.
            </p>
          )}
          <p class="mt-8 text-sm text-[var(--color-ink-soft)]">
            To book a service, please call <a href="tel:+61755478064" class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)]">07 5547 8064</a> or
            email <a href="mailto:info@ssvk.org.au" class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)]">info@ssvk.org.au</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ARCHANA GUIDE */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">How to Worship</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Archana Guide</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">அர்ச்சனை வழிகாட்டி</p>
          <p class="text-sm text-[var(--color-ink-soft)] leading-relaxed">
            Pay on arrival, collect a receipt, and the Archana will be performed by the temple priest.
          </p>
        </div>
        <div class="lg:col-span-8 space-y-10">

          {/* Walk-in Archanas */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Walk-in Archanas</h3>
            <div class="divide-y divide-[var(--color-rule)]">
              {[
                { name: 'Standard Archanai', note: 'With oil lamp, ghee lamp & fruit', price: 5 },
                { name: 'Oil Lamp / Ghee Lamp', note: '', price: 5 },
                { name: 'Fruit Archanai', note: '', price: 10 },
                { name: 'Archana Basket', note: 'Basket with fruits & incense sticks', price: 21 },
                { name: 'Moksha Archanai', note: 'For departed souls — performed with ghee lamp', price: 21 },
                { name: 'Special Poojai', note: 'Ganesh Coin/statue, fruits & incense sticks', price: 51 },
              ].map((item) => (
                <div class="grid grid-cols-12 gap-4 items-baseline py-4">
                  <div class="col-span-8">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    {item.note && <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>}
                  </div>
                  <div class="col-span-4 text-right">
                    <p class="text-2xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">${item.price}.00</p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Kumkuma Archanas */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Kumkuma Archanas</h3>
            <p class="text-sm text-[var(--color-ink-soft)] mb-4">Available for Abhirami Amman, Vishnu Durga & Siva Durga</p>
            <div class="divide-y divide-[var(--color-rule)]">
              {[
                { name: 'Astotra Kumkuma Archana', note: '108 names', price: 51 },
                { name: 'Thirisathy Kumkuma Archana', note: '300 names', price: 75 },
              ].map((item) => (
                <div class="grid grid-cols-12 gap-4 items-baseline py-4">
                  <div class="col-span-8">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>
                  </div>
                  <div class="col-span-4 text-right">
                    <p class="text-2xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">${item.price}.00</p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Nama Archanas */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Nama Archanas</h3>
            <p class="text-sm text-[var(--color-ink-soft)] mb-4">Available for Pillaiyar, Sivan, Murugan, Anjaneyar, Maha Vishnu, Venkadeswavar & Bhairavar</p>
            <div class="divide-y divide-[var(--color-rule)]">
              {[
                { name: 'Astotra Archana', note: '108 names', price: 51 },
                { name: 'Thirisathy Nama Archana', note: '300 names', price: 75 },
                { name: 'Santhana Kaapu (Thirisathy)', note: '300 names', price: 75 },
                { name: 'Sahasranama Archana', note: '1000 names — devotees to bring flowers, fruits & one coconut. Sponsor receives one prasadam.', price: 150 },
              ].map((item) => (
                <div class="grid grid-cols-12 gap-4 items-baseline py-4">
                  <div class="col-span-8">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>
                  </div>
                  <div class="col-span-4 text-right">
                    <p class="text-2xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">${item.price}.00</p>
                    <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* SPONSORED PUJAS & ABISHEKAMS */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">By Arrangement</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Sponsored Pujas & Abishekams</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">சிறப்பு பூஜை & அபிஷேகம்</p>
          <p class="text-sm text-[var(--color-ink-soft)] leading-relaxed">
            All sponsored pujas and abishekams are performed only during normal temple opening hours.
            Payment must be made in advance and the receipt produced to the priest before commencement.
            All necessary materials and neivetham are provided by the temple.
            Thakshanai (Dakshina) may be given to the priest at the devotee's discretion.
          </p>
        </div>
        <div class="lg:col-span-8 space-y-10">

          {/* Sponsored Pujas */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Sponsored Pujas</h3>
            <div class="divide-y divide-[var(--color-rule)]">
              {[
                { name: 'Kuru Poojai', note: 'Devotees to bring fruits, flowers & five coconuts', price: 75 },
                { name: 'Sathyanarayana Poojai', note: 'Devotees to bring fruits, flowers & five coconuts', price: 101 },
                { name: 'Vadai Malai', note: 'Can be ordered through the priest', price: null },
                { name: 'Mothaka Poojai', note: 'Mothakam can be ordered through the priest. Poojai with Neivetham available.', price: null },
                { name: 'Thiruvembavai', note: 'Devotees to bring fruits, flowers & five coconuts', price: null },
              ].map((item) => (
                <div class="grid grid-cols-12 gap-4 items-baseline py-4">
                  <div class="col-span-8">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>
                  </div>
                  <div class="col-span-4 text-right">
                    {item.price ? (
                      <>
                        <p class="text-2xl font-[var(--font-display)] text-[var(--color-ink)]" style="font-weight: 500;">${item.price}.00</p>
                        <p class="eyebrow !text-[0.6rem] eyebrow-mute">AUD</p>
                      </>
                    ) : (
                      <p class="text-sm text-[var(--color-ink-mute)] italic">enquire</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Sponsored Abishekams */}
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Sponsored Abishekams</h3>
            <div class="space-y-4">
              {[
                { name: 'Paal Abishekam', note: 'Abishekam with milk. Sponsor receives one prasadam.' },
                { name: 'Thiraviya Abishekam', note: 'Sponsor receives one prasadam.' },
                { name: 'Nava Kalasa Abishekam', note: 'On a regular day. Sponsor receives two prasadams.' },
                { name: 'Nava Kalasa Abishekam (Special Days)', note: 'During special festival days. Sponsor receives two prasadams.' },
                { name: 'Sankadahara Chathurthi / Monthly Chathurthi Abishekam', note: 'Includes circumambulation of the inner sanctum. (Excludes Aavani Chathurthi.) Sponsor receives prasadam.' },
                { name: 'Navagrana Homam & Abishekam', note: 'Sponsor receives prasadam.' },
                { name: 'Sangabishekam', note: 'Abishekam performed with a conch (shankh). Sponsor receives prasadam.' },
              ].map((item, i) => (
                <div class={`grid grid-cols-12 gap-4 items-start ${i > 0 ? 'border-t border-[var(--color-rule)] pt-4' : ''}`}>
                  <div class="col-span-12">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>
                  </div>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm text-[var(--color-ink-mute)] border-l-2 border-[var(--color-rule)] pl-4">
              Additional prasadams can be ordered by contacting the priest in advance.
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>

  {/* TEMPLE FESTIVAL PROCEDURE */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Festival Observance</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Festival Procedures</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">திருவிழா நடைமுறை</p>
        </div>
        <div class="lg:col-span-8 space-y-10">
          <div class="prose-content text-[var(--color-ink-soft)] text-base leading-relaxed space-y-4">
            <p>
              Temple festivals for various deities are arranged as prescribed in the Agama Shastras. Dates are published separately in the Special Days & Festivals calendar.
            </p>
            <p>
              Devotees may sponsor any festival through the temple priest. Payment must be made in advance and the receipt produced before the festival commences.
            </p>
          </div>
          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Festival Sponsorship</h3>
            <div class="space-y-4">
              <div class="grid grid-cols-12 gap-4 items-start">
                <div class="col-span-12">
                  <p class="font-medium text-[var(--color-ink)]">Thiru Kalyanam</p>
                  <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">
                    Includes Abishekam and Alankara Puja of Utsava Moorthy and circumambulation of inner and outer sanctum.
                    Sponsor receives one prasadam. Devotee to provide Thiru Mangalyam.
                  </p>
                </div>
              </div>
              <div class="grid grid-cols-12 gap-4 items-start border-t border-[var(--color-rule)] pt-4">
                <div class="col-span-12">
                  <p class="font-medium text-[var(--color-ink)]">Alankara Puja of Utsava Moorthy</p>
                  <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">Sponsor receives two prasadams.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* LIFE EVENTS & OTHER FUNCTIONS */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-5">Life Events</p>
          <h2 class="text-[var(--color-ink)] mb-4" style="font-weight: 400;">Other Functions</h2>
          <p lang="ta" class="tamil-display !text-3xl mb-6">வாழ்க்கை நிகழ்வுகள்</p>
          <p class="text-sm text-[var(--color-ink-soft)] leading-relaxed">
            Please consult the priest for the necessary materials required for each function.
            Thakshanai (Dakshina) may be given at the devotee's discretion.
          </p>
        </div>
        <div class="lg:col-span-8 space-y-10">

          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">At the Temple</h3>
            <div class="space-y-4">
              {[
                { name: 'Naamakaranam', note: 'Naming ceremony for newborns' },
                { name: 'Annaprasannam', note: 'First rice-feeding ceremony' },
                { name: 'Vidyarambham', note: 'Initiation into learning. Devotees to bring fruits, flowers, rice, coconut, candy, sugar & a small bottle of honey.' },
                { name: 'Karnavethanam', note: 'Ear-piercing ceremony' },
                { name: 'Offering newborn to Deity', note: 'Presenting newborn to the deity and buying back' },
                { name: 'Blessing of Vehicles', note: '' },
                { name: 'Wedding Short Ceremony', note: 'Pillaiyar Poojai and Thali tying only' },
                { name: 'Ayush Homam', note: 'Longevity homam' },
                { name: 'Thivastam / Shradh', note: 'Ancestral rites — can be arranged with the priest' },
              ].map((item, i) => (
                <div class={`grid grid-cols-12 gap-4 items-start ${i > 0 ? 'border-t border-[var(--color-rule)] pt-4' : ''}`}>
                  <div class="col-span-12">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    {item.note && <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-base uppercase tracking-widest text-[var(--color-ink-mute)] mb-4 pb-2 border-b border-[var(--color-rule)]">Outside the Temple</h3>
            <p class="text-sm text-[var(--color-ink-soft)] mb-4">
              The priest will bring brass utensils (pots, lamps), navathaniayam and homa thiraviyam.
              Devotees must provide flowers, fruits, coconuts, rice, camphor, ghee, mango leaves and dried mango twigs for homam.
            </p>
            <div class="space-y-4">
              {[
                { name: 'Wedding Full Ceremony — Temple Hall', note: '' },
                { name: 'Wedding Full Ceremony — Other Venues', note: '' },
                { name: 'Grahapravesam (Full Ceremony)', note: 'Includes Ganapathy Homam, Laxmi Homam & Navagrana Homam' },
                { name: 'Grahapravesam (Ganapathy Homam only)', note: 'Includes Ganapathy Homam, Punyavachanam & Pada Poojai' },
                { name: 'Grahapravesam (Basic Ceremony)', note: 'Ganapathy Poojai, Punyavachanam & Pada Poojai' },
                { name: 'Foundation Ceremony', note: 'Punyaha Vaachanam & Thudakku Kalivu' },
                { name: 'Upanayanam', note: 'Sacred thread ceremony' },
                { name: 'Ayush Homam', note: '' },
                { name: 'Thivastam / Chabindikaranam', note: '1st day ceremony after death' },
              ].map((item, i) => (
                <div class={`grid grid-cols-12 gap-4 items-start ${i > 0 ? 'border-t border-[var(--color-rule)] pt-4' : ''}`}>
                  <div class="col-span-12">
                    <p class="font-medium text-[var(--color-ink)]">{item.name}</p>
                    {item.note && <p class="text-sm text-[var(--color-ink-soft)] mt-0.5">{item.note}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <p class="text-sm text-[var(--color-ink-mute)] border-l-2 border-[var(--color-rule)] pl-4">
            For bookings please contact the temple priest or the Temple President at
            <a href="mailto:hasqpresident@gmail.com" class="text-[var(--color-saffron)] ml-1">hasqpresident@gmail.com</a>
          </p>

        </div>
      </div>
    </div>
  </section>

  {/* LIBRARY */}
  <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
    <div class="container-tight max-w-4xl space-y-20">

      {/* Koyil Mani Magazine */}
      <div>
        <div class="border-t border-[var(--color-rule)] pt-10 mb-10">
          <p class="eyebrow mb-3">Temple Magazine</p>
          <h2 class="text-[var(--color-ink)] text-3xl" style="font-weight: 400;">Koyil Mani</h2>
          <p lang="ta" class="tamil-display !text-2xl mt-2">கோயில் மணி</p>
        </div>
        {koyilMani.length > 0 ? (
          <div class="divide-y divide-[var(--color-rule)]">
            {koyilMani.map((d) => (
              <div class="py-5 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-lg text-[var(--color-ink)] font-medium">{d.title}</h3>
                  {d.description && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{d.description}</p>}
                  {d.date && (
                    <p class="text-xs text-[var(--color-ink-mute)] mt-1">
                      {new Date(d.date).toLocaleDateString('en-AU', { month: 'long', year: 'numeric' })}
                    </p>
                  )}
                </div>
                <a
                  href={d.pdfUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-secondary !py-2 !px-4 !min-h-[36px] text-xs whitespace-nowrap flex-shrink-0"
                >
                  Download PDF
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="card text-[var(--color-ink-soft)] italic">No Koyil Mani issues published yet.</p>
        )}
      </div>

      {/* Temple Worship Series */}
      <div>
        <div class="border-t border-[var(--color-rule)] pt-10 mb-10">
          <p class="eyebrow mb-3">Worship Guides</p>
          <h2 class="text-[var(--color-ink)] text-3xl" style="font-weight: 400;">Temple Worship Series</h2>
          <p class="text-[var(--color-ink-soft)] mt-3 text-base leading-relaxed max-w-xl">
            A series of worship guides by Sri Santhan Kurukkal, covering temple rituals and devotional practices.
          </p>
        </div>
        {worshipSeries.length > 0 ? (
          <div class="divide-y divide-[var(--color-rule)]">
            {worshipSeries.map((d) => (
              <div class="py-5 flex items-center justify-between gap-4">
                <div>
                  <h3 class="text-lg text-[var(--color-ink)] font-medium">{d.title}</h3>
                  {d.description && <p class="text-sm text-[var(--color-ink-soft)] mt-1">{d.description}</p>}
                </div>
                <a
                  href={d.pdfUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-secondary !py-2 !px-4 !min-h-[36px] text-xs whitespace-nowrap flex-shrink-0"
                >
                  Download PDF
                </a>
              </div>
            ))}
          </div>
        ) : (
          <p class="card text-[var(--color-ink-soft)] italic">No worship guides published yet.</p>
        )}
      </div>

    </div>
  </section>
</Layout>
