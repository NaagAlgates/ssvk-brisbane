---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import CanteenStatus from '~/components/CanteenStatus.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let canteen: any = null;
let menu: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  canteen = await reader.singletons.canteenStatus.read();
  menu = await reader.collections.canteenMenu.all();
} catch {}

const availableMenu = menu
  .map((m) => ({ ...m.entry, slug: m.slug }))
  .filter((m) => m.available);

const dosas    = availableMenu.filter((m) => m.category === 'breakfast');
const varieties = availableMenu.filter((m) => m.category === 'lunch');
const snacks   = availableMenu.filter((m) => m.category === 'snacks');
const drinks   = availableMenu.filter((m) => m.category === 'drinks');
---
<Layout title="Temple Canteen · Kamadhenu">

  {/* Hero */}
  <section class="pt-32 md:pt-44 pb-12">
    <div class="container-tight max-w-4xl">
      <p class="eyebrow mb-6">Temple Canteen</p>
      <h1 class="text-[var(--color-ink)] mb-4 text-balance" style="font-weight: 400;">Sri Selva Vinayakar Koyil Canteen</h1>
      <p class="text-lg text-[var(--color-ink-soft)] leading-relaxed mb-4">
        Come & Enjoy freshly made, mouth-watering vegetarian delicacies in the serene natural surrounds.
      </p>
      <p lang="ta" class="tamil-display mb-10">கோயில் உணவகம்</p>
    </div>
  </section>

  {/* Opening hours band */}
  <section class="border-y border-[var(--color-rule)] bg-[var(--color-paper-soft)]">
    <div class="container-tight py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
          <p class="eyebrow mb-2" style="color: var(--color-saffron);">Open This Weekend</p>
          <h2 class="text-[var(--color-ink)] text-3xl" style="font-weight: 400;">Saturday & Sunday · {canteen?.weekendOpenTime ?? '9:00am'} – {canteen?.weekendCloseTime ?? '2:00pm'}</h2>
          {canteen?.openingNote && <p class="text-sm text-[var(--color-ink-soft)] mt-2">{canteen.openingNote}</p>}
        </div>
        <div class="px-5 py-3 bg-[var(--color-paper)] border border-[var(--color-rule)]">
          <CanteenStatus canteen={canteen ?? {}} variant="pill" />
        </div>
      </div>
      {canteen?.specialNotice && (
        <p class="mt-6 text-[var(--color-saffron)] italic text-sm">{canteen.specialNotice}</p>
      )}
    </div>
  </section>

  {/* DOSA MENU */}
  {dosas.length > 0 && (
    <section class="py-24 md:py-32">
      <div class="container-tight">
        <div class="mb-12">
          <p class="eyebrow mb-3" style="color: var(--color-saffron);">Dosa Menu</p>
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Varieties of Dosas</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {dosas.map((item) => (
            <div class="bg-[var(--color-paper-soft)] rounded-sm overflow-hidden border border-[var(--color-rule)] hover:border-[var(--color-saffron)] transition-colors">
              {item.photo && (
                <div class="aspect-[4/3] overflow-hidden">
                  <img
                    src={`/images/menu/${item.photo}`}
                    alt={item.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-4">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <div>
                    <p class="font-medium text-[var(--color-ink)] leading-tight">{item.name}</p>
                    {item.nameTamil && <p lang="ta" class="text-xs text-[var(--color-ink-soft)] tamil-body mt-0.5">{item.nameTamil}</p>}
                  </div>
                  <p class="text-lg font-[var(--font-display)] text-[var(--color-saffron)] whitespace-nowrap" style="font-weight: 600;">${item.price?.toFixed(2)}</p>
                </div>
                {item.description && <p class="text-xs text-[var(--color-ink-mute)] leading-snug mt-1">{item.description}</p>}
              </div>
            </div>
          ))}
        </div>
        {canteen?.dosaSideNote && <p class="mt-4 text-xs text-[var(--color-ink-mute)]">{canteen.dosaSideNote}</p>}
      </div>
    </section>
  )}

  {/* VARIETIES */}
  {varieties.length > 0 && (
    <section class="py-24 md:py-32 border-t border-[var(--color-rule)] bg-[var(--color-paper-soft)]">
      <div class="container-tight">
        <div class="mb-12">
          <p class="eyebrow mb-3" style="color: var(--color-saffron);">Varieties & Combos</p>
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">More to Enjoy</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
          {varieties.map((item) => (
            <div class="bg-[var(--color-paper)] rounded-sm overflow-hidden border border-[var(--color-rule)] hover:border-[var(--color-saffron)] transition-colors">
              {item.photo && (
                <div class="aspect-square overflow-hidden">
                  <img
                    src={`/images/menu/${item.photo}`}
                    alt={item.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-3">
                <div class="flex items-start justify-between gap-1 mb-1">
                  <div>
                    <p class="font-medium text-[var(--color-ink)] text-sm leading-tight">{item.name}</p>
                    {item.nameTamil && <p lang="ta" class="text-xs text-[var(--color-ink-mute)] tamil-body mt-0.5">{item.nameTamil}</p>}
                  </div>
                  <p class="text-base font-[var(--font-display)] text-[var(--color-saffron)] whitespace-nowrap" style="font-weight: 600;">${item.price?.toFixed(2)}</p>
                </div>
                {item.description && <p class="text-xs text-[var(--color-ink-mute)] leading-snug mt-1">{item.description}</p>}
              </div>
            </div>
          ))}
        </div>
        {canteen?.varietiesNote && <p class="mt-4 text-xs text-[var(--color-ink-mute)]">{canteen.varietiesNote}</p>}
      </div>
    </section>
  )}

  {/* SNACKS */}
  {snacks.length > 0 && (
    <section class="py-24 md:py-32 border-t border-[var(--color-rule)]">
      <div class="container-tight">
        <div class="mb-12">
          <p class="eyebrow mb-3" style="color: var(--color-saffron);">Snacks</p>
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Freshly Made</h2>
        </div>
        <div class="grid sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {snacks.map((item) => (
            <div class="bg-[var(--color-paper-soft)] rounded-sm overflow-hidden border border-[var(--color-rule)] hover:border-[var(--color-saffron)] transition-colors">
              {item.photo && (
                <div class="aspect-square overflow-hidden">
                  <img
                    src={`/images/menu/${item.photo}`}
                    alt={item.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-3">
                <div class="flex items-start justify-between gap-1 mb-1">
                  <div>
                    <p class="font-medium text-[var(--color-ink)] text-sm leading-tight">{item.name}</p>
                    {item.nameTamil && <p lang="ta" class="text-xs text-[var(--color-ink-mute)] tamil-body mt-0.5">{item.nameTamil}</p>}
                  </div>
                  <p class="text-base font-[var(--font-display)] text-[var(--color-saffron)] whitespace-nowrap" style="font-weight: 600;">${item.price?.toFixed(2)}</p>
                </div>
                {item.description && <p class="text-xs text-[var(--color-ink-mute)]">{item.description}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* DRINKS */}
  {drinks.length > 0 && (
    <section class="py-24 md:py-32 border-t border-[var(--color-rule)] bg-[var(--color-paper-soft)]">
      <div class="container-tight">
        <div class="mb-12">
          <p class="eyebrow mb-3" style="color: var(--color-saffron);">Beverages</p>
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Drinks</h2>
        </div>
        <div class="grid sm:grid-cols-3 lg:grid-cols-5 gap-4">
          {drinks.map((item) => (
            <div class="bg-[var(--color-paper)] rounded-sm overflow-hidden border border-[var(--color-rule)] hover:border-[var(--color-saffron)] transition-colors">
              {item.photo && (
                <div class="aspect-square overflow-hidden">
                  <img
                    src={`/images/menu/${item.photo}`}
                    alt={item.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-3">
                <div class="flex items-start justify-between gap-1 mb-1">
                  <div>
                    <p class="font-medium text-[var(--color-ink)] text-sm leading-tight">{item.name}</p>
                    {item.nameTamil && <p lang="ta" class="text-xs text-[var(--color-ink-mute)] tamil-body mt-0.5">{item.nameTamil}</p>}
                  </div>
                  <p class="text-base font-[var(--font-display)] text-[var(--color-saffron)] whitespace-nowrap" style="font-weight: 600;">${item.price?.toFixed(2)}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Contact strip */}
  <section class="py-16 border-t border-[var(--color-rule)]">
    <div class="container-tight text-center space-y-2">
      <p class="text-[var(--color-ink-soft)] text-sm">4915–4923 Mount Lindesay Hwy, South MacLean QLD 4280</p>
      <p class="text-[var(--color-ink-soft)] text-sm">
        <a href="mailto:hasq.secretary@gmail.com" class="text-[var(--color-saffron)]">hasq.secretary@gmail.com</a>
        &nbsp;·&nbsp;
        <a href="tel:+61755477302" class="text-[var(--color-saffron)]">(07) 5547 7302</a>
      </p>
    </div>
  </section>

</Layout>
