---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let canteen: any = { isOpen: true, todayHoursOpen: '11:00am', todayHoursClose: '8:00pm' };
let hours: any = null;
let festivals: any[] = [];
let notices: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  canteen = (await reader.singletons.canteenStatus.read()) ?? canteen;
  hours = await reader.singletons.openingHours.read();
  festivals = await reader.collections.festivals.all();
  notices = await reader.collections.notices.all();
} catch {
  // Pre-content fallback
}

const today = new Date();
const upcoming = festivals
  .map((f) => ({ ...f.entry, slug: f.slug }))
  .filter((f) => new Date(f.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 3);

const activeNotices = notices
  .map((n) => ({ ...n.entry, slug: n.slug }))
  .filter((n) => !n.expiresOn || new Date(n.expiresOn) >= today)
  .sort((a, b) => new Date(b.datePosted).getTime() - new Date(a.datePosted).getTime())
  .slice(0, 1);
---
<Layout title="Home">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-maroon-700)] via-[var(--color-maroon-900)] to-[var(--color-charcoal)] opacity-95"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, var(--color-saffron-500) 0%, transparent 40%), radial-gradient(circle at 80% 70%, var(--color-saffron-500) 0%, transparent 40%);"></div>
    <div class="container-tight relative py-20 md:py-32 text-center">
      <p class="text-[var(--color-saffron-500)] tracking-widest uppercase text-sm mb-4">
        Welcome to
      </p>
      <h1 class="text-[var(--color-cream-50)] mb-2" style="color: var(--color-cream-50);">
        Sri Selva Vinayakar Koyil
      </h1>
      <p class="text-[var(--color-saffron-500)] text-xl md:text-2xl mb-3" lang="ta">
        ஸ்ரீ செல்வ விநாயகர் கோயில்
      </p>
      <p class="text-[var(--color-cream-200)] text-lg mb-10 max-w-2xl mx-auto">
        Ganesha Temple, Brisbane · Serving the Tamil Hindu community of South-East Queensland since 1995
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/services" class="btn btn-secondary">View Festival Calendar</a>
        <a href="/visit" class="btn btn-primary" style="border: 1px solid var(--color-saffron-500);">Plan your visit →</a>
      </div>
    </div>
  </section>

  {activeNotices.length > 0 && (
    <section class="container-tight -mt-8 relative z-10">
      <div class="card border-l-4" style="border-left-color: var(--color-saffron-500);">
        <p class="text-xs uppercase tracking-wider text-[var(--color-saffron-600)] font-semibold mb-1">
          Notice
        </p>
        <h3 class="!text-lg !mb-2">{activeNotices[0].title}</h3>
      </div>
    </section>
  )}

  <section class="container-tight py-16 grid gap-6 md:grid-cols-3">
    <article class="card">
      <p class="text-xs uppercase tracking-wider text-[var(--color-saffron-600)] font-semibold mb-2">Canteen</p>
      <p class="text-2xl font-bold mb-1" style={`color: ${canteen.isOpen ? 'var(--color-maroon-700)' : 'var(--color-charcoal-soft)'};`}>
        {canteen.isOpen ? '🟢 Open today' : '🔴 Closed today'}
      </p>
      {canteen.isOpen && (
        <p class="text-[var(--color-charcoal-soft)]">
          {canteen.todayHoursOpen} – {canteen.todayHoursClose}
        </p>
      )}
      {canteen.specialNotice && <p class="text-sm mt-2 italic">{canteen.specialNotice}</p>}
    </article>
    <article class="card">
      <p class="text-xs uppercase tracking-wider text-[var(--color-saffron-600)] font-semibold mb-2">Today's Pooja</p>
      <p class="font-semibold text-lg">{hours?.poojaMorning ?? '9:00am – 9:30am'}</p>
      <p class="text-[var(--color-charcoal-soft)]">{hours?.poojaEvening ?? '7:00pm – 7:30pm'}</p>
    </article>
    <article class="card">
      <p class="text-xs uppercase tracking-wider text-[var(--color-saffron-600)] font-semibold mb-2">Opening</p>
      <p class="font-semibold">Mon–Fri: 7:30am – 8:30pm</p>
      <p class="text-[var(--color-charcoal-soft)]">Sat–Sun: 7:30am – 8:30pm</p>
    </article>
  </section>

  <section class="container-tight py-12">
    <div class="flex items-baseline justify-between mb-6">
      <h2>Upcoming Festivals</h2>
      <a href="/services" class="text-sm">View all →</a>
    </div>
    <span class="kolam-divider" aria-hidden="true"></span>
    {upcoming.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-3">
        {upcoming.map((f) => (
          <article class="card">
            <p class="text-xs uppercase tracking-wider text-[var(--color-saffron-600)] font-semibold mb-2">
              {new Date(f.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <h3 class="!text-xl !mb-1">{f.name}</h3>
            <p lang="ta" class="text-[var(--color-charcoal-soft)] mb-2">{f.nameTamil}</p>
            {f.time && <p class="text-sm">⏰ {f.time}</p>}
          </article>
        ))}
      </div>
    ) : (
      <p class="text-center text-[var(--color-charcoal-soft)] italic">
        Festival calendar will appear here once added via the admin panel.
      </p>
    )}
  </section>
</Layout>
