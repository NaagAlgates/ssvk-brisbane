---
import Layout from '~/layouts/Layout.astro';
import CanteenStatus from '~/components/CanteenStatus.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let canteen: any = {};
let hours: any = null;
let festivals: any[] = [];
let notices: any[] = [];
let site: any = null;

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  canteen = (await reader.singletons.canteenStatus.read()) ?? canteen;
  hours = await reader.singletons.openingHours.read();
  festivals = await reader.collections.festivals.all();
  notices = await reader.collections.notices.all();
  site = await reader.singletons.siteConfig.read();
} catch {}

const today = new Date();
const upcoming = festivals
  .map((f) => ({ ...f.entry, slug: f.slug }))
  .filter((f) => new Date(f.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 3);

const nextFestival = upcoming[0];
const daysToNext = nextFestival
  ? Math.ceil((new Date(nextFestival.date).getTime() - today.getTime()) / (1000 * 60 * 60 * 24))
  : null;

const addr = site ?? {
  templeAddressLine1: '4915–4923 Mt Lindesay Highway',
  suburb: 'South Maclean',
  state: 'QLD',
  postcode: '4280',
  country: 'Australia',
  phonePrimary: '+61 7 5547 8064',
  emailGeneral: 'info@ssvk.org.au',
  googleMapsUrl: 'https://www.google.com/maps/search/?api=1&query=Sri+Selva+Vinayakar+Koyil+South+Maclean',
};
export const prerender = true;
---
<Layout title="Home">
  {/* EDITORIAL HERO with WOW typography + Om watermark + Ken Burns photo */}
  <section class="relative overflow-hidden pt-36 md:pt-48 pb-16">
    <span class="om-watermark" style="top: 8rem; right: -4rem;" aria-hidden="true">ॐ</span>
    <div class="container-tight max-w-6xl relative">
      <p class="eyebrow mb-6 hero-fade-up">Est. 1995 · South Maclean · Brisbane</p>
      <h1 class="text-[var(--color-ink)] mb-6 text-balance hero-fade-up hero-fade-up-delay-1">
        A sacred space.<br/>Right here in Brisbane.
      </h1>
      <p lang="ta" class="tamil-display mb-10 !text-2xl md:!text-4xl hero-fade-up hero-fade-up-delay-2">
        ஸ்ரீ செல்வ விநாயகர் கோயில்
      </p>
      <p class="text-lg md:text-xl text-[var(--color-ink-soft)] mb-10 max-w-2xl leading-relaxed hero-fade-up hero-fade-up-delay-3">
        Sri Selva Vinayakar Koyil — a traditional Hindu Ganesha temple beside
        the Logan River, serving the community of South-East Queensland for
        three decades.
      </p>
      <div class="flex flex-wrap gap-3 hero-fade-up hero-fade-up-delay-4">
        <a href="#visit-us" class="btn btn-primary">Plan your visit</a>
        <a href="/events" class="btn btn-ghost">Festival calendar</a>
      </div>
    </div>
  </section>

  {/* CINEMATIC AERIAL — birds-eye drone shot of the full complex */}
  <section class="container-wide pb-12">
    <div class="aspect-[16/9] photo-frame">
      <img
        src="/images/temple-birds-view.jpg"
        alt="Aerial view of Sri Selva Vinayakar Koyil — the full temple complex in its bushland setting"
        class="ken-burns"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  {/* STATS STRIP — wow numbers */}
  <section class="py-20 md:py-28 bg-[var(--color-paper-soft)] border-y border-[var(--color-rule)]">
    <div class="container-tight grid grid-cols-2 md:grid-cols-4 gap-y-12 gap-x-8 text-center">
      <div>
        <p class="stat-number text-[var(--color-saffron)]">30</p>
        <p class="eyebrow mt-3 eyebrow-mute">Years of worship</p>
        <p class="text-sm text-[var(--color-ink-soft)] mt-1">Since 1995</p>
      </div>
      <div>
        <p class="stat-number">4.5</p>
        <p class="eyebrow mt-3 eyebrow-mute">Acres of grounds</p>
        <p class="text-sm text-[var(--color-ink-soft)] mt-1">By the Logan River</p>
      </div>
      <div>
        <p class="stat-number">35<span class="text-2xl align-top ml-1">km</span></p>
        <p class="eyebrow mt-3 eyebrow-mute">South of Brisbane</p>
        <p class="text-sm text-[var(--color-ink-soft)] mt-1">Mt Lindesay Hwy</p>
      </div>
      <div>
        <p class="stat-number text-[var(--color-teal)]">Daily</p>
        <p class="eyebrow mt-3 eyebrow-mute">Pooja & Worship</p>
        <p class="text-sm text-[var(--color-ink-soft)] mt-1">Morning & evening</p>
      </div>
    </div>
  </section>

  {/* LIVE STATUS BAND — light register */}
  <section class="bg-[var(--color-paper-soft)] border-y border-[var(--color-rule)]">
    <div class="container-tight grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--color-rule)]">
      <div class="py-7 px-2 md:px-8">
        <CanteenStatus canteen={canteen} variant="pill" />
      </div>
      <div class="py-7 px-2 md:px-8 flex items-center gap-4">
        <span class="text-[var(--color-saffron)] text-xl">◐</span>
        <div>
          <p class="eyebrow !text-[0.6rem] eyebrow-mute">Today's Pooja</p>
          <p class="text-[var(--color-ink)] font-medium mt-1">
            {hours?.poojaMorning ?? '9:00am – 9:30am'} · {hours?.poojaEvening ?? '7:00pm – 7:30pm'}
          </p>
        </div>
      </div>
      <div class="py-7 px-2 md:px-8 flex items-center gap-4">
        <span class="text-[var(--color-saffron)] text-xl">⌂</span>
        <div>
          <p class="eyebrow !text-[0.6rem] eyebrow-mute">Open Daily</p>
          <p class="text-[var(--color-ink)] font-medium mt-1">Morning & Evening</p>
        </div>
      </div>
    </div>
  </section>

  {/* TAMIL SUTRA — quiet contemplative band */}
  <section class="py-28 md:py-40">
    <div class="container-tight max-w-3xl mx-auto text-center">
      <p lang="ta" class="font-[var(--font-tamil-display)] text-[var(--color-ink)] text-3xl md:text-5xl leading-relaxed mb-8 font-medium">
        விநாயகனே வெவ்வினையை<br/>வேரறுக்க வல்லான்
      </p>
      <span class="block w-12 h-px bg-[var(--color-saffron)] mx-auto mb-6"></span>
      <p class="text-[var(--color-ink-soft)] italic text-lg">
        Lord Vinayaka alone has the power to uproot the deepest of obstacles.
      </p>
    </div>
  </section>

  {/* NEXT FESTIVAL — VIBRANT REGISTER (D3 accents) */}
  {nextFestival && (
    <section class="festival-section py-24 md:py-32">
      <div class="container-tight grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-5 flex flex-col justify-center">
          <p class="eyebrow accent-vermillion mb-6" style="color: var(--color-saffron);">Next Festival</p>
          <h2 class="text-[var(--color-ink)] mb-3" style="font-weight: 400;">
            {nextFestival.name}
          </h2>
          <p lang="ta" class="tamil-display !text-[var(--color-teal)] mb-10">{nextFestival.nameTamil}</p>
          <div class="flex items-baseline gap-8 mb-10">
            <div>
              <p class="text-[var(--color-saffron)] font-[var(--font-display)] font-light leading-none" style="font-size: clamp(4rem, 12vw, 8rem);">
                {daysToNext}
              </p>
              <p class="eyebrow mt-3" style="color: var(--color-teal);">Days away</p>
            </div>
            <div class="border-l border-[var(--color-rule)] pl-6">
              <p class="text-[var(--color-ink)] text-lg font-medium">
                {new Date(nextFestival.date).toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              {nextFestival.time && (
                <p class="text-[var(--color-ink-soft)] text-sm mt-1">{nextFestival.time}</p>
              )}
            </div>
          </div>
          <a href="/events" class="btn btn-ghost self-start">View full calendar →</a>
        </div>
        <div class="lg:col-span-7">
          <div class="aspect-[4/3] photo-frame">
            <img
              src="/images/chariot-reflection.jpg"
              alt="Temple chariot procession reflected in water — Theer festival"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {/* UPCOMING FESTIVALS — vibrant cards */}
  {upcoming.length > 1 && (
    <section class="py-24 md:py-32">
      <div class="container-tight">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-6">
          <div>
            <p class="eyebrow mb-3" style="color: var(--color-saffron);">Sacred Calendar</p>
            <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Upcoming festivals</h2>
          </div>
          <a href="/events" class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)] text-sm tracking-wide">
            View all →
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {upcoming.map((f, i) => {
            const accentColor = i === 0 ? 'var(--color-saffron)' : i === 1 ? 'var(--color-teal)' : 'var(--color-saffron)';
            return (
              <article class="festival-card card-hover" style={`border-left-color: ${accentColor};`}>
                <p class="text-sm tracking-wider uppercase mb-4 font-semibold" style={`color: ${accentColor};`}>
                  {new Date(f.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' })}
                </p>
                <h3 class="text-[var(--color-ink)] mb-2">{f.name}</h3>
                <p lang="ta" class="text-[var(--color-ink-soft)] tamil-body mb-4">
                  {f.nameTamil}
                </p>
                {f.time && (
                  <p class="text-[var(--color-ink-mute)] text-sm">{f.time}</p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* CLOSING — Visit Us with address + hours bento cards */}
  <section class="py-24 md:py-32 bg-[var(--color-paper-soft)]" id="visit-us">
    <div class="container-tight">
      <div class="max-w-2xl mb-16">
        <p class="eyebrow mb-6">Visit Us</p>
        <h2 class="text-[var(--color-ink)] mb-6" style="font-weight: 400;">
          Come and be part of a living tradition
        </h2>
        <p class="text-[var(--color-ink-soft)] text-lg mb-10 leading-relaxed">
          35 km south of Brisbane, beside the Logan River — a place of peace and inspiration
          for devotees, families, and visitors from every community.
        </p>
        <a href="/donate" class="btn btn-ghost">Support the temple</a>
      </div>

      <div class="grid lg:grid-cols-12 gap-6">
        <div class="lg:col-span-7 card card-hover">
          <p class="eyebrow mb-4">Where to find us</p>
          <p class="text-2xl md:text-3xl font-[var(--font-display)] text-[var(--color-ink)] mb-2 leading-snug">
            {addr.templeAddressLine1}
          </p>
          <p class="text-[var(--color-ink-soft)] text-lg mb-6">
            {addr.suburb} {addr.state} {addr.postcode} · {addr.country}
          </p>
          <a href={addr.googleMapsUrl} target="_blank" rel="noopener" class="btn btn-primary mb-8">
            Open in Google Maps ↗
          </a>
          <div class="border-t border-[var(--color-rule)] pt-6 grid sm:grid-cols-2 gap-6">
            <div>
              <p class="eyebrow mb-2">Phone</p>
              <a href={`tel:${addr.phonePrimary}`} class="text-[var(--color-ink)] hover:text-[var(--color-saffron)] text-lg">
                {addr.phonePrimary}
              </a>
            </div>
            <div>
              <p class="eyebrow mb-2">Email</p>
              <a href={`mailto:${addr.emailGeneral}`} class="text-[var(--color-ink)] hover:text-[var(--color-saffron)] text-lg">
                {addr.emailGeneral}
              </a>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5 card card-hover">
          <div class="flex items-center justify-between mb-4">
            <p class="eyebrow">Opening Hours</p>
            <span id="temple-status" class="hidden text-xs px-2.5 py-1 rounded-full font-medium"></span>
          </div>
          <div class="space-y-5 mb-6">
            <div>
              <p class="text-[var(--color-ink)] font-semibold mb-1">Monday – Friday</p>
              <p class="text-[var(--color-ink-soft)]">{hours?.weekdayMorningOpen ?? '7:30am'} – {hours?.weekdayMorningClose ?? '12:00pm'}</p>
              <p class="text-[var(--color-ink-soft)]">{hours?.weekdayEveningOpen ?? '5:00pm'} – {hours?.weekdayEveningClose ?? '8:30pm'}</p>
            </div>
            <div>
              <p class="text-[var(--color-ink)] font-semibold mb-1">Saturday – Sunday</p>
              <p class="text-[var(--color-ink-soft)]">{hours?.weekendMorningOpen ?? '7:30am'} – {hours?.weekendMorningClose ?? '1:00pm'}</p>
              <p class="text-[var(--color-ink-soft)]">{hours?.weekendEveningOpen ?? '5:00pm'} – {hours?.weekendEveningClose ?? '8:30pm'}</p>
            </div>
          </div>
          <div class="border-t border-[var(--color-rule)] pt-4">
            <p class="eyebrow mb-2">Pooja Times</p>
            <p class="text-[var(--color-saffron)] text-lg font-medium">{hours?.poojaMorning ?? '9:00am – 9:30am'}</p>
            <p class="text-[var(--color-saffron)] text-lg font-medium">{hours?.poojaEvening ?? '7:00pm – 7:30pm'}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  (function () {
    const badge = document.getElementById('temple-status');
    if (!badge) return;
    const now = new Date();
    // Convert to Brisbane time (AEST = UTC+10, no daylight saving in Queensland)
    const bris = new Date(now.toLocaleString('en-AU', { timeZone: 'Australia/Brisbane' }));
    const day = bris.getDay(); // 0=Sun, 1=Mon, ..., 6=Sat
    const mins = bris.getHours() * 60 + bris.getMinutes();
    const isWeekend = day === 0 || day === 6;
    // Open windows in minutes from midnight
    const windows = isWeekend
      ? [[450, 780], [1020, 1230]]  // 7:30am–1:00pm, 5:00pm–8:30pm
      : [[450, 720], [1020, 1230]]; // 7:30am–12:00pm, 5:00pm–8:30pm
    const isOpen = windows.some(([s, e]) => mins >= s && mins < e);
    badge.textContent = isOpen ? 'Open Now' : 'Closed';
    badge.style.background = isOpen ? 'rgba(34,197,94,0.12)' : 'rgba(0,0,0,0.06)';
    badge.style.color = isOpen ? '#16a34a' : 'var(--color-ink-mute)';
    badge.classList.remove('hidden');
  })();
</script>
