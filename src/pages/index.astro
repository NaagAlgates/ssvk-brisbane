---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let canteen: any = { isOpen: true, todayHoursOpen: '11:00am', todayHoursClose: '8:00pm' };
let hours: any = null;
let festivals: any[] = [];
let notices: any[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  canteen = (await reader.singletons.canteenStatus.read()) ?? canteen;
  hours = await reader.singletons.openingHours.read();
  festivals = await reader.collections.festivals.all();
  notices = await reader.collections.notices.all();
} catch {}

const today = new Date();
const upcoming = festivals
  .map((f) => ({ ...f.entry, slug: f.slug }))
  .filter((f) => new Date(f.date) >= today)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 3);

const nextFestival = upcoming[0];
const daysToNext = nextFestival
  ? Math.ceil((new Date(nextFestival.date).getTime() - today.getTime()) / (1000 * 60 * 60 * 24))
  : null;
---
<Layout title="Home">
  {/* QUIET ARCHITECTURAL HERO — register A */}
  <section class="relative min-h-screen flex flex-col">
    {/* Photo as a serene backdrop, full color */}
    <div class="absolute inset-0 photo-frame">
      <img
        src="/images/temple-front.jpg"
        alt="The gopuram of Sri Selva Vinayakar Koyil at South Maclean"
        class="hidden md:block w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <img
        src="/images/temple-portrait.jpg"
        alt="The temple's gopuram tower"
        class="md:hidden w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      {/* Very gentle paper-tinted bottom fade — keeps photo at 80%+ visibility */}
      <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[var(--color-paper)] to-transparent"></div>
    </div>

    {/* Text content positioned at bottom — quiet, monumental */}
    <div class="relative mt-auto pb-20 md:pb-32 pt-32">
      <div class="container-tight">
        <div class="max-w-4xl">
          <p class="eyebrow mb-8" style="color: var(--color-kumkum); background: var(--color-paper); display: inline-block; padding: 6px 14px;">
            Est. 1995 · South Maclean
          </p>
          <h1 lang="ta" class="tamil-monumental mb-6 text-balance">
            ஸ்ரீ செல்வ விநாயகர் கோயில்
          </h1>
          <p class="text-2xl md:text-3xl font-[var(--font-display)] text-[var(--color-ink)] mb-8 italic">
            Sri Selva Vinayakar Koyil
          </p>
          <span class="block w-16 h-px bg-[var(--color-kumkum)] mb-8"></span>
          <p class="text-lg md:text-xl text-[var(--color-ink-soft)] mb-10 max-w-xl leading-relaxed">
            A traditional Hindu Ganesha temple serving the Tamil community of South-East
            Queensland — beside the Logan River, 35km south of Brisbane.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/visit" class="btn btn-primary">Plan your visit</a>
            <a href="/services" class="btn btn-ghost">Festival calendar</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* LIVE STATUS BAND — light register */}
  <section class="bg-[var(--color-paper-soft)] border-y border-[var(--color-rule)]">
    <div class="container-tight grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--color-rule)]">
      <div class="py-7 px-2 md:px-8 flex items-center gap-4">
        <span class={`w-2.5 h-2.5 rounded-full ${canteen.isOpen ? 'bg-[var(--color-teal)] animate-pulse' : 'bg-[var(--color-vermillion)]'}`}></span>
        <div>
          <p class="eyebrow !text-[0.6rem] eyebrow-mute">Canteen</p>
          <p class="text-[var(--color-ink)] font-medium mt-1">
            {canteen.isOpen ? `Open · ${canteen.todayHoursOpen} – ${canteen.todayHoursClose}` : 'Closed today'}
          </p>
        </div>
      </div>
      <div class="py-7 px-2 md:px-8 flex items-center gap-4">
        <span class="text-[var(--color-kumkum)] text-xl">◐</span>
        <div>
          <p class="eyebrow !text-[0.6rem] eyebrow-mute">Today's Pooja</p>
          <p class="text-[var(--color-ink)] font-medium mt-1">
            {hours?.poojaMorning ?? '9:00am – 9:30am'} · {hours?.poojaEvening ?? '7:00pm – 7:30pm'}
          </p>
        </div>
      </div>
      <div class="py-7 px-2 md:px-8 flex items-center gap-4">
        <span class="text-[var(--color-kumkum)] text-xl">⌂</span>
        <div>
          <p class="eyebrow !text-[0.6rem] eyebrow-mute">Open Daily</p>
          <p class="text-[var(--color-ink)] font-medium mt-1">Morning & Evening</p>
        </div>
      </div>
    </div>
  </section>

  {/* TAMIL SUTRA — quiet contemplative band */}
  <section class="py-28 md:py-40">
    <div class="container-tight max-w-3xl mx-auto text-center">
      <p lang="ta" class="font-[var(--font-tamil-display)] text-[var(--color-ink)] text-3xl md:text-5xl leading-relaxed mb-8 font-medium">
        விநாயகனே வெவ்வினையை<br/>வேரறுக்க வல்லான்
      </p>
      <span class="block w-12 h-px bg-[var(--color-kumkum)] mx-auto mb-6"></span>
      <p class="text-[var(--color-ink-soft)] italic text-lg">
        Lord Vinayaka alone has the power to uproot the deepest of obstacles.
      </p>
    </div>
  </section>

  {/* NEXT FESTIVAL — VIBRANT REGISTER (D3 accents) */}
  {nextFestival && (
    <section class="festival-section py-24 md:py-32">
      <div class="container-tight grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-5 flex flex-col justify-center">
          <p class="eyebrow accent-vermillion mb-6" style="color: var(--color-vermillion);">Next Festival</p>
          <h2 class="text-[var(--color-ink)] mb-3" style="font-weight: 400;">
            {nextFestival.name}
          </h2>
          <p lang="ta" class="tamil-display !text-[var(--color-teal)] mb-10">{nextFestival.nameTamil}</p>
          <div class="flex items-baseline gap-8 mb-10">
            <div>
              <p class="text-[var(--color-vermillion)] font-[var(--font-display)] font-light leading-none" style="font-size: clamp(4rem, 12vw, 8rem);">
                {daysToNext}
              </p>
              <p class="eyebrow mt-3" style="color: var(--color-teal);">Days away</p>
            </div>
            <div class="border-l border-[var(--color-rule)] pl-6">
              <p class="text-[var(--color-ink)] text-lg font-medium">
                {new Date(nextFestival.date).toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              {nextFestival.time && (
                <p class="text-[var(--color-ink-soft)] text-sm mt-1">{nextFestival.time}</p>
              )}
            </div>
          </div>
          <a href="/services" class="btn btn-ghost self-start">View full calendar →</a>
        </div>
        <div class="lg:col-span-7">
          <div class="aspect-[4/3] photo-frame">
            <img
              src="/images/chariot-reflection.jpg"
              alt="Temple chariot procession reflected in water — Theer festival"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  {/* UPCOMING FESTIVALS — vibrant cards */}
  {upcoming.length > 1 && (
    <section class="py-24 md:py-32">
      <div class="container-tight">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-14 gap-6">
          <div>
            <p class="eyebrow mb-3" style="color: var(--color-vermillion);">Sacred Calendar</p>
            <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Upcoming festivals</h2>
          </div>
          <a href="/services" class="text-[var(--color-kumkum)] hover:text-[var(--color-kumkum-soft)] text-sm tracking-wide">
            View all →
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {upcoming.map((f, i) => {
            const accentColor = i === 0 ? 'var(--color-vermillion)' : i === 1 ? 'var(--color-teal)' : 'var(--color-kumkum)';
            return (
              <article class="festival-card card-hover" style={`border-left-color: ${accentColor};`}>
                <p class="text-sm tracking-wider uppercase mb-4 font-semibold" style={`color: ${accentColor};`}>
                  {new Date(f.date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' })}
                </p>
                <h3 class="text-[var(--color-ink)] mb-2">{f.name}</h3>
                <p lang="ta" class="text-[var(--color-ink-soft)] tamil-body mb-4">
                  {f.nameTamil}
                </p>
                {f.time && (
                  <p class="text-[var(--color-ink-mute)] text-sm">{f.time}</p>
                )}
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {/* CLOSING — quiet register with photo */}
  <section class="py-24 md:py-32 bg-[var(--color-paper-soft)]">
    <div class="container-tight grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5">
        <p class="eyebrow mb-6">Visit Us</p>
        <h2 class="text-[var(--color-ink)] mb-6" style="font-weight: 400;">
          Come and be part of a living tradition
        </h2>
        <p class="text-[var(--color-ink-soft)] text-lg mb-10 leading-relaxed">
          35 km south of Brisbane, beside the Logan River — a place of peace and inspiration
          for devotees, families, and visitors from every community.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/visit" class="btn btn-primary">Directions & hours</a>
          <a href="/donate" class="btn btn-ghost">Support the temple</a>
        </div>
      </div>
      <div class="lg:col-span-7">
        <div class="aspect-[16/10] photo-frame">
          <img src="/images/temple-wide.jpg" alt="Wide view of the temple grounds" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
</Layout>
