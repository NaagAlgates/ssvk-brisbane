---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let donation: any = null;
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  donation = await reader.singletons.donation.read({ resolveLinkedFiles: true });
} catch {}

const d = donation ?? {
  bankName: 'Commonwealth Bank',
  accountName: 'Hindu Ahlaya Sangam Queensland Inc.',
  bsb: '064-000',
  accountNumber: '00906257',
  treasurerEmail: 'treasurer@ssvk.org.au',
};
export const prerender = true;
---
<Layout title="Donate" description="Support Sri Selva Vinayakar Koyil Ganesha Temple in Brisbane. Your donations help maintain temple operations, festivals, and services for the Hindu community of South-East Queensland.">
  {/* Quiet hero with text */}
  <section class="pt-32 md:pt-44 pb-12">
    <div class="container-tight max-w-3xl">
      <p class="eyebrow mb-6">Support the temple</p>
      <h1 class="text-[var(--color-ink)] mb-6 text-balance" style="font-weight: 400;">
        Sustain a place of devotion
      </h1>
      <p lang="ta" class="tamil-display mb-8">தர்மம் தலை காக்கும்</p>
      <p class="text-[var(--color-ink-soft)] text-xl leading-relaxed max-w-2xl">
        Your donations sustain the daily worship, festivals, and ongoing care of the temple.
        Every contribution — large or small — keeps a sacred space alive for our community.
      </p>
    </div>
  </section>

  {/* Warm photo for gravitas */}
  <section class="container-tight">
    <div class="aspect-[21/8] photo-frame">
      <img src="/images/temple-front.jpg" alt="The temple gopuram in morning light" loading="eager" />
    </div>
  </section>

  {/* Donation card — premium minimal on paper-soft */}
  <section class="py-24 md:py-32">
    <div class="container-tight max-w-3xl">
      <div class="card card-hover">
        <div class="flex items-baseline justify-between mb-8 pb-6 border-b border-[var(--color-rule)]">
          <h2 class="text-[var(--color-ink)]" style="font-weight: 400;">Direct bank transfer</h2>
          <span class="eyebrow eyebrow-mute">AUD</span>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-3 gap-y-6 gap-x-6">
          <dt class="eyebrow">Bank</dt>
          <dd class="md:col-span-2 text-[var(--color-ink)] text-lg font-medium">{d.bankName}</dd>

          <dt class="eyebrow">Account name</dt>
          <dd class="md:col-span-2 text-[var(--color-ink)] text-lg font-medium">{d.accountName}</dd>

          <dt class="eyebrow">BSB</dt>
          <dd class="md:col-span-2 font-mono text-2xl font-[var(--font-display)] text-[var(--color-saffron)]">{d.bsb}</dd>

          <dt class="eyebrow">Account number</dt>
          <dd class="md:col-span-2 font-mono text-2xl font-[var(--font-display)] text-[var(--color-saffron)]">{d.accountNumber}</dd>

          {d.payid && (
            <>
              <dt class="eyebrow">PayID</dt>
              <dd class="md:col-span-2 text-[var(--color-ink)] text-lg font-medium">{d.payid}</dd>
            </>
          )}
        </dl>

        <div class="mt-10 pt-6 border-t border-[var(--color-rule)]">
          <p class="text-sm text-[var(--color-ink-soft)] leading-relaxed">
            <strong class="text-[var(--color-saffron)]">Receipt request:</strong>
            email a copy of your transfer confirmation to
            <a href={`mailto:${d.treasurerEmail}`} class="text-[var(--color-saffron)] hover:text-[var(--color-saffron-soft)] underline underline-offset-4">
              {d.treasurerEmail}
            </a>.
          </p>
        </div>
      </div>

      <div class="mt-16 text-center">
        <p lang="ta" class="tamil-display !text-2xl !text-[var(--color-ink-soft)] mb-3">தர்மம் ஈய்க</p>
        <p class="text-[var(--color-ink-soft)] italic">
          "Anything given with devotion finds its way to the Divine."
        </p>
      </div>
    </div>
  </section>
</Layout>
