---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let donation: any = null;
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  donation = await reader.singletons.donation.read({ resolveLinkedFiles: true });
} catch {}

const d = donation ?? {
  bankName: 'Commonwealth Bank',
  accountName: 'Hindu Ahlaya Sangam Queensland Inc.',
  bsb: '064-000',
  accountNumber: '00906257',
  treasurerEmail: 'treasurer@ssvk.org.au',
};
---
<Layout title="Donate">
  <section class="container-tight py-12 md:py-20">
    <p class="text-[var(--color-saffron-600)] uppercase tracking-widest text-sm mb-2">Support</p>
    <h1 class="mb-4">Donate to the Temple</h1>
    <span class="kolam-divider" aria-hidden="true"></span>
    <p class="text-lg max-w-2xl mt-6 leading-relaxed">
      Your donations support the daily worship, festivals, and ongoing maintenance of the temple.
      Donations can be made directly to the temple bank account below.
    </p>
  </section>

  <section class="container-tight pb-16">
    <div class="card max-w-2xl">
      <h2 class="!text-2xl !mb-6">Bank Transfer</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <dt class="text-sm uppercase tracking-wider text-[var(--color-charcoal-soft)] font-semibold">Bank</dt>
        <dd class="sm:col-span-2 font-medium">{d.bankName}</dd>

        <dt class="text-sm uppercase tracking-wider text-[var(--color-charcoal-soft)] font-semibold">Account name</dt>
        <dd class="sm:col-span-2 font-medium">{d.accountName}</dd>

        <dt class="text-sm uppercase tracking-wider text-[var(--color-charcoal-soft)] font-semibold">BSB</dt>
        <dd class="sm:col-span-2 font-mono font-semibold text-lg">{d.bsb}</dd>

        <dt class="text-sm uppercase tracking-wider text-[var(--color-charcoal-soft)] font-semibold">Account number</dt>
        <dd class="sm:col-span-2 font-mono font-semibold text-lg">{d.accountNumber}</dd>

        {d.payid && (
          <>
            <dt class="text-sm uppercase tracking-wider text-[var(--color-charcoal-soft)] font-semibold">PayID</dt>
            <dd class="sm:col-span-2 font-medium">{d.payid}</dd>
          </>
        )}
      </dl>
      <div class="mt-8 p-4 rounded-lg bg-[var(--color-cream-100)] text-sm">
        <p class="font-semibold mb-1">📧 To receive a receipt:</p>
        <p>
          Please email a copy of your transfer confirmation to
          <a href={`mailto:${d.treasurerEmail}`} class="font-semibold">{d.treasurerEmail}</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
