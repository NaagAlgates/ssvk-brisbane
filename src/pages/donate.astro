---
import Layout from '~/layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let donation: any = null;
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  donation = await reader.singletons.donation.read({ resolveLinkedFiles: true });
} catch {}

const d = donation ?? {
  bankName: 'Commonwealth Bank',
  accountName: 'Hindu Ahlaya Sangam Queensland Inc.',
  bsb: '064-000',
  accountNumber: '00906257',
  treasurerEmail: 'treasurer@ssvk.org.au',
};
---
<Layout title="Donate">
  {/* Subtle hero */}
  <section class="pt-32 md:pt-44 pb-12 relative">
    <div class="container-tight max-w-3xl">
      <p class="eyebrow mb-6">Support the temple</p>
      <h1 class="text-[var(--color-cream-50)] mb-6 text-balance" style="font-weight: 400;">
        Sustain a place of devotion
      </h1>
      <p lang="ta" class="display-tamil mb-8">தர்மம் தலை காக்கும்</p>
      <p class="text-[var(--color-cream-200)] text-xl leading-relaxed max-w-2xl">
        Your donations sustain the daily worship, festivals, and ongoing care of the temple.
        Every contribution — large or small — keeps a sacred space alive for our community.
      </p>
    </div>
  </section>

  {/* Donation card */}
  <section class="pb-24 md:pb-32">
    <div class="container-tight max-w-3xl">
      <div class="card card-elevated">
        <div class="flex items-baseline justify-between mb-8 pb-6 border-b border-[var(--color-ink-600)]">
          <h2 class="text-[var(--color-cream-50)]" style="font-weight: 400;">Direct bank transfer</h2>
          <span class="eyebrow">AUD</span>
        </div>
        <dl class="grid grid-cols-1 md:grid-cols-3 gap-y-6 gap-x-6">
          <dt class="eyebrow">Bank</dt>
          <dd class="md:col-span-2 text-[var(--color-cream-50)] text-lg font-medium">{d.bankName}</dd>

          <dt class="eyebrow">Account name</dt>
          <dd class="md:col-span-2 text-[var(--color-cream-50)] text-lg font-medium">{d.accountName}</dd>

          <dt class="eyebrow">BSB</dt>
          <dd class="md:col-span-2 font-mono text-2xl font-[var(--font-display)] text-[var(--color-gold-400)]">{d.bsb}</dd>

          <dt class="eyebrow">Account number</dt>
          <dd class="md:col-span-2 font-mono text-2xl font-[var(--font-display)] text-[var(--color-gold-400)]">{d.accountNumber}</dd>

          {d.payid && (
            <>
              <dt class="eyebrow">PayID</dt>
              <dd class="md:col-span-2 text-[var(--color-cream-50)] text-lg font-medium">{d.payid}</dd>
            </>
          )}
        </dl>

        <div class="mt-10 pt-6 border-t border-[var(--color-ink-600)]">
          <p class="text-sm text-[var(--color-cream-200)] leading-relaxed">
            <strong class="text-[var(--color-gold-300)]">Receipt request:</strong>
            email a copy of your transfer confirmation to
            <a href={`mailto:${d.treasurerEmail}`} class="text-[var(--color-gold-400)] hover:text-[var(--color-gold-300)] underline underline-offset-4">
              {d.treasurerEmail}
            </a>.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-[var(--color-cream-300)] italic">
          "Anything given with devotion finds its way to the Divine."
        </p>
      </div>
    </div>
  </section>
</Layout>
