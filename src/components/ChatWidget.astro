---
---
<div id="chat-widget">
  <button id="chat-toggle" aria-label="Open temple assistant" title="Ask the temple assistant">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  </button>

  <div id="chat-panel" role="dialog" aria-label="Temple assistant" aria-modal="true" hidden>
    <div id="chat-header">
      <div>
        <p id="chat-title">Temple Assistant</p>
        <p id="chat-subtitle">Ask about hours, pooja, canteen &amp; more</p>
      </div>
      <button id="chat-close" aria-label="Close assistant">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div id="chat-messages">
      <div class="msg msg-bot">
        <p>வணக்கம்! I can help with temple hours, pooja services, canteen menu, directions, and more. What would you like to know?</p>
      </div>
    </div>

    <form id="chat-form" autocomplete="off">
      <input
        id="chat-input"
        type="text"
        placeholder="Ask about the temple…"
        maxlength="300"
        aria-label="Your question"
      />
      <button type="submit" id="chat-send" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  #chat-widget {
    position: fixed;
    bottom: 80px;
    right: 20px;
    z-index: 100;
    font-family: var(--font-sans);
  }
  @media (min-width: 768px) {
    #chat-widget { bottom: 24px; }
  }

  #chat-toggle {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: var(--color-saffron);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(194,65,12,0.35);
    transition: background 200ms ease, transform 200ms ease;
    margin-left: auto;
  }
  #chat-toggle:hover { background: var(--color-saffron-soft); transform: scale(1.06); }

  #chat-panel {
    position: absolute;
    bottom: 64px;
    right: 0;
    width: 340px;
    max-height: 480px;
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: 16px;
    box-shadow: 0 8px 40px -8px rgba(26,24,21,0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  @media (max-width: 400px) {
    #chat-panel { width: calc(100vw - 32px); right: -8px; }
  }
  #chat-panel[hidden] { display: none; }

  #chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: var(--color-saffron);
    color: white;
    flex-shrink: 0;
  }
  #chat-title { font-weight: 600; font-size: 0.9rem; margin: 0; }
  #chat-subtitle { font-size: 0.7rem; opacity: 0.85; margin: 2px 0 0; }
  #chat-close {
    background: transparent;
    border: none;
    color: white;
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    opacity: 0.85;
  }
  #chat-close:hover { opacity: 1; }

  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
  }

  :global(.msg) {
    max-width: 78%;
    font-size: 0.875rem;
    line-height: 1.5;
    word-break: break-word;
  }
  :global(.msg p) { margin: 0; }
  :global(.msg-bot) {
    align-self: flex-start;
    background: #f0ece6;
    border-radius: 2px 16px 16px 16px;
    padding: 9px 13px;
    color: var(--color-ink);
    box-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }
  :global(.msg-user) {
    align-self: flex-end;
    background: var(--color-saffron);
    border-radius: 16px 2px 16px 16px;
    padding: 9px 13px;
    color: white;
    box-shadow: 0 1px 2px rgba(0,0,0,0.12);
  }
  :global(.msg-typing) { display: flex; align-items: center; gap: 4px; padding: 12px 13px; background: #f0ece6; border-radius: 2px 16px 16px 16px; align-self: flex-start; box-shadow: 0 1px 2px rgba(0,0,0,0.08); }
  :global(.msg-typing .dot) {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-ink-mute);
    animation: blink 1.2s infinite;
  }
  :global(.msg-typing .dot:nth-child(2)) { animation-delay: 0.2s; }
  :global(.msg-typing .dot:nth-child(3)) { animation-delay: 0.4s; }
  @keyframes blink {
    0%, 80%, 100% { opacity: 0.25; }
    40% { opacity: 1; }
  }

  #chat-form {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid var(--color-rule);
    flex-shrink: 0;
    background: var(--color-paper);
  }
  #chat-input {
    flex: 1;
    border: 1px solid var(--color-rule-strong);
    border-radius: 999px;
    padding: 9px 14px;
    font-size: 0.875rem;
    font-family: var(--font-sans);
    color: var(--color-ink);
    background: white;
    outline: none;
    transition: border-color 200ms;
  }
  #chat-input:focus { border-color: var(--color-saffron); }
  #chat-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-saffron);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 200ms;
  }
  #chat-send:hover { background: var(--color-saffron-soft); }
  #chat-send:disabled { background: var(--color-rule-strong); cursor: not-allowed; }
</style>

<script>
  const toggle = document.getElementById('chat-toggle')!;
  const panel  = document.getElementById('chat-panel')!;
  const close  = document.getElementById('chat-close')!;
  const form   = document.getElementById('chat-form')!;
  const input  = document.getElementById('chat-input') as HTMLInputElement;
  const send   = document.getElementById('chat-send') as HTMLButtonElement;
  const msgs   = document.getElementById('chat-messages')!;

  let history: Array<{ role: string; content: string }> = [];

  const openPanel  = () => { panel.hidden = false; input.focus(); };
  const closePanel = () => { panel.hidden = true; };
  toggle.addEventListener('click', () => panel.hidden ? openPanel() : closePanel());
  close.addEventListener('click', closePanel);

  const scrollBottom = () => msgs.scrollTo({ top: msgs.scrollHeight, behavior: 'smooth' });

  const addMsg = (text: string, role: 'user' | 'bot') => {
    const div = document.createElement('div');
    div.className = `msg msg-${role}`;
    const p = document.createElement('p');
    p.textContent = text;
    div.appendChild(p);
    msgs.appendChild(div);
    scrollBottom();
  };

  const showTyping = () => {
    const div = document.createElement('div');
    div.className = 'msg msg-bot msg-typing';
    for (let i = 0; i < 3; i++) {
      const dot = document.createElement('span');
      dot.className = 'dot';
      div.appendChild(dot);
    }
    msgs.appendChild(div);
    scrollBottom();
    return div;
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    send.disabled = true;
    addMsg(text, 'user');
    history.push({ role: 'user', content: text });

    const typing = showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: history.slice(-8) }),
      });
      const data = await res.json() as { reply?: string; error?: string };
      typing.remove();
      const reply = data.reply ?? data.error ?? 'Sorry, something went wrong.';
      addMsg(reply, 'bot');
      history.push({ role: 'assistant', content: reply });
    } catch {
      typing.remove();
      addMsg('Connection error. Please try again.', 'bot');
    } finally {
      send.disabled = false;
      input.focus();
    }
  });
</script>
