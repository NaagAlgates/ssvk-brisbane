---
/*
  Canteen status, computed at build time in Australia/Brisbane timezone
  for an instant, flash-free render. A tiny client-side script then
  verifies against the viewer's actual local day and corrects silently
  only if there's a mismatch (e.g. viewer outside Brisbane TZ near
  midnight rollover).

  Admin "mode" options:
    - auto         → open Sat/Sun with weekend hours, closed weekdays
    - force_open   → always open today with override hours
    - force_closed → always closed today
*/

interface Props {
  canteen: {
    mode?: string;
    weekendOpenTime?: string;
    weekendCloseTime?: string;
    overrideOpenTime?: string;
    overrideCloseTime?: string;
    specialNotice?: string;
  };
  variant?: 'pill' | 'block';
}
const { canteen, variant = 'pill' } = Astro.props;
const c = canteen ?? {};
const mode = c.mode ?? 'auto';
const weekendOpen = c.weekendOpenTime ?? '9:00am';
const weekendClose = c.weekendCloseTime ?? '2:00pm';
const overrideOpen = c.overrideOpenTime ?? '9:00am';
const overrideClose = c.overrideCloseTime ?? '2:00pm';

// Compute today in Brisbane TZ (build-time best guess)
const brisbaneDayShort = new Intl.DateTimeFormat('en-AU', {
  timeZone: 'Australia/Brisbane',
  weekday: 'short',
}).format(new Date());
const isWeekendBuild = brisbaneDayShort === 'Sat' || brisbaneDayShort === 'Sun';

function compute(mode: string, weekend: boolean) {
  if (mode === 'force_open') {
    return { isOpen: true, openTime: overrideOpen, closeTime: overrideClose };
  }
  if (mode === 'force_closed') {
    return { isOpen: false, openTime: '', closeTime: '' };
  }
  // auto
  return weekend
    ? { isOpen: true, openTime: weekendOpen, closeTime: weekendClose }
    : { isOpen: false, openTime: '', closeTime: '' };
}

const initial = compute(mode, isWeekendBuild);
---
<div
  class="canteen-status-host"
  data-mode={mode}
  data-weekend-open={weekendOpen}
  data-weekend-close={weekendClose}
  data-override-open={overrideOpen}
  data-override-close={overrideClose}
  data-variant={variant}
>
  {variant === 'pill' ? (
    <div class="flex items-center gap-4">
      <span
        class:list={['canteen-dot w-2.5 h-2.5 rounded-full', initial.isOpen && 'animate-pulse']}
        style={`background-color: ${initial.isOpen ? 'var(--color-teal)' : 'var(--color-saffron)'};`}
        data-open-color="var(--color-teal)"
        data-closed-color="var(--color-saffron)"
      ></span>
      <div>
        <p class="eyebrow !text-[0.6rem] eyebrow-mute">Canteen</p>
        <p class="canteen-text text-[var(--color-ink)] font-medium mt-1">
          {initial.isOpen
            ? `Open · ${initial.openTime} – ${initial.closeTime}`
            : 'Closed today'}
        </p>
      </div>
    </div>
  ) : (
    <div>
      <p
        class="canteen-text text-2xl font-bold"
        style={`color: ${initial.isOpen ? 'var(--color-saffron)' : 'var(--color-ink-soft)'};`}
      >
        {initial.isOpen ? '🟢 Open today' : '🔴 Closed today'}
      </p>
      {initial.isOpen && (
        <p class="canteen-hours text-lg text-[var(--color-ink-soft)] mt-1">
          {initial.openTime} – {initial.closeTime}
        </p>
      )}
    </div>
  )}
</div>

<script>
  // Client-side verification: re-check using the viewer's local day.
  // Only re-renders if the build-time guess (Brisbane TZ) differs from
  // the viewer's actual day (e.g. someone overseas near midnight).
  function updateCanteen(el: HTMLElement) {
    const mode = el.dataset.mode ?? 'auto';
    const variant = el.dataset.variant ?? 'pill';
    const weekendOpen = el.dataset.weekendOpen ?? '9:00am';
    const weekendClose = el.dataset.weekendClose ?? '2:00pm';
    const overrideOpen = el.dataset.overrideOpen ?? '9:00am';
    const overrideClose = el.dataset.overrideClose ?? '2:00pm';

    const day = new Date().getDay(); // 0 Sun, 6 Sat in viewer's local TZ
    const isWeekend = day === 0 || day === 6;

    let isOpen = false;
    let openTime = weekendOpen;
    let closeTime = weekendClose;

    if (mode === 'force_open') {
      isOpen = true;
      openTime = overrideOpen;
      closeTime = overrideClose;
    } else if (mode === 'force_closed') {
      isOpen = false;
    } else {
      isOpen = isWeekend;
    }

    const dot = el.querySelector<HTMLElement>('.canteen-dot');
    if (dot) {
      const openColor = dot.dataset.openColor ?? 'var(--color-teal)';
      const closedColor = dot.dataset.closedColor ?? 'var(--color-saffron)';
      dot.style.backgroundColor = isOpen ? openColor : closedColor;
      dot.classList.toggle('animate-pulse', isOpen);
    }

    const text = el.querySelector<HTMLElement>('.canteen-text');
    if (text) {
      if (variant === 'pill') {
        text.textContent = isOpen ? `Open · ${openTime} – ${closeTime}` : 'Closed today';
      } else {
        text.textContent = isOpen ? '🟢 Open today' : '🔴 Closed today';
        text.style.color = isOpen ? 'var(--color-saffron)' : 'var(--color-ink-soft)';
        let hoursEl = el.querySelector<HTMLElement>('.canteen-hours');
        if (isOpen) {
          if (!hoursEl) {
            hoursEl = document.createElement('p');
            hoursEl.className = 'canteen-hours text-lg text-[var(--color-ink-soft)] mt-1';
            text.insertAdjacentElement('afterend', hoursEl);
          }
          hoursEl.textContent = `${openTime} – ${closeTime}`;
        } else if (hoursEl) {
          hoursEl.remove();
        }
      }
    }
  }

  document.querySelectorAll<HTMLElement>('.canteen-status-host').forEach(updateCanteen);
</script>
