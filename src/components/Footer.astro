---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let site: any = null;
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  site = await reader.singletons.siteConfig.read();
} catch {}

const year = new Date().getFullYear();
---
<footer class="mt-32 pb-32 md:pb-12 bg-[var(--color-paper-soft)] border-t border-[var(--color-rule)]">
  <div class="container-tight pt-20 grid gap-12 md:grid-cols-12">
    <div class="md:col-span-6">
      <p class="font-[var(--font-display)] text-3xl text-[var(--color-ink)] mb-3 leading-tight">
        Sri Selva Vinayakar Koyil
      </p>
      <p lang="ta" class="tamil-display !text-2xl !text-[var(--color-saffron)] mb-5">ஸ்ரீ செல்வ விநாயகர் கோயில்</p>
      <p class="text-[var(--color-ink-soft)] text-sm leading-relaxed max-w-md">
        A traditional Hindu Ganesha temple serving the community of South-East
        Queensland. Consecrated 5 February 1995.
      </p>
      {(site?.facebookUrl || site?.youtubeUrl) && (
        <div class="flex items-center gap-4 mt-6">
          {site?.facebookUrl && (
            <a href={site.facebookUrl} target="_blank" rel="noopener" class="text-[var(--color-ink-mute)] hover:text-[var(--color-saffron)] transition-colors" aria-label="Facebook">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          )}
          {site?.youtubeUrl && (
            <a href={site.youtubeUrl} target="_blank" rel="noopener" class="text-[var(--color-ink-mute)] hover:text-[var(--color-saffron)] transition-colors" aria-label="YouTube">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/>
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
    <div class="md:col-span-3">
      <p class="eyebrow mb-4">Contact</p>
      <p class="text-sm text-[var(--color-ink)] leading-relaxed">
        <a href={`tel:${site?.phonePrimary ?? '+61755478064'}`} class="block hover:text-[var(--color-saffron)]">
          {site?.phonePrimary ?? '+61 7 5547 8064'}
        </a>
        <a href={`mailto:${site?.emailGeneral ?? 'info@ssvk.org.au'}`} class="block hover:text-[var(--color-saffron)]">
          {site?.emailGeneral ?? 'info@ssvk.org.au'}
        </a>
      </p>
      <p class="mt-4 text-sm text-[var(--color-ink-soft)]">
        {site?.templeAddressLine1 ?? '4915–4923 Mt Lindesay Hwy'}<br />
        {site?.suburb ?? 'South Maclean'} {site?.state ?? 'QLD'} {site?.postcode ?? '4280'}
      </p>
    </div>
    <div class="md:col-span-3">
      <p class="eyebrow mb-4">Visit</p>
      <ul class="text-sm space-y-2 text-[var(--color-ink)]">
        <li><a href="/#visit-us" class="hover:text-[var(--color-saffron)]">Opening Hours</a></li>
        <li><a href="/services" class="hover:text-[var(--color-saffron)]">Pooja & Services</a></li>
        <li><a href="/services" class="hover:text-[var(--color-saffron)]">Festival Calendar</a></li>
        <li><a href="/donate" class="hover:text-[var(--color-saffron)]">Donate</a></li>
      </ul>
    </div>
  </div>
  <div class="container-tight border-t border-[var(--color-rule)] mt-12 pt-6 flex flex-col md:flex-row justify-between text-xs text-[var(--color-ink-mute)]">
    <p>A devotee-made website · Offered as digital seva</p>
    <p class="mt-2 md:mt-0">Crafted with devotion by <a href="https://jcube.com.au" target="_blank" rel="noopener" class="hover:text-[var(--color-saffron)] transition-colors">Jcube Software Solutions</a></p>
  </div>
</footer>
