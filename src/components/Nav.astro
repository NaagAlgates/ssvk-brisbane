---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/news', label: 'News' },
  { href: '/library', label: 'Library' },
  { href: '/visit', label: 'Visit' },
  { href: '/donate', label: 'Donate' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="absolute top-0 inset-x-0 z-50 bg-transparent">
  <div class="container-tight flex items-center justify-between py-6">
    <a href="/" class="flex items-baseline gap-3 no-underline group">
      <span class="font-[var(--font-display)] leading-tight">
        <span class="block text-base md:text-lg font-semibold tracking-wide text-[var(--color-ink)]">
          SSVK
        </span>
      </span>
      <span class="hidden md:block text-[0.65rem] tracking-[0.3em] uppercase text-[var(--color-saffron)] font-semibold">
        Brisbane
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="hidden md:flex items-center gap-1">
        {links.slice(0, -1).map((l) => (
          <li>
            <a
              href={l.href}
              class={`px-4 py-2 text-sm font-medium transition-colors ${
                path === l.href
                  ? 'text-[var(--color-saffron)]'
                  : 'text-[var(--color-ink)] hover:text-[var(--color-saffron)]'
              }`}
            >
              {l.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/donate" class="ml-2 btn btn-primary !py-2 !px-5 !min-h-[40px] text-xs">
            Donate
          </a>
        </li>
      </ul>
    </nav>
  </div>

  {/* Mobile bottom nav */}
  <nav aria-label="Mobile" class="md:hidden fixed bottom-0 inset-x-0 bg-[var(--color-paper)]/95 backdrop-blur border-t border-[var(--color-rule)] z-50">
    <ul class="grid grid-cols-7">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`flex flex-col items-center justify-center py-3 text-[0.7rem] tracking-wide no-underline ${
              path === l.href ? 'text-[var(--color-saffron)] font-semibold' : 'text-[var(--color-ink-soft)]'
            }`}
            style="min-height: 56px;"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
