---
const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/visit', label: 'Visit' },
  { href: '/donate', label: 'Donate' },
];
const path = Astro.url.pathname;
---
<header class="absolute top-0 inset-x-0 z-50 md:bg-transparent">
  <div class="container-tight flex items-center justify-between py-6">
    <a href="/" class="flex items-center gap-3 no-underline group">
      <span class="font-[var(--font-display)] leading-tight">
        <span class="block text-base md:text-lg font-semibold tracking-wide text-[var(--color-cream-50)]">
          SSVK
        </span>
        <span class="block text-[0.65rem] tracking-[0.25em] uppercase text-[var(--color-gold-400)]">
          Brisbane
        </span>
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="hidden md:flex items-center gap-1">
        {links.slice(1).map((l) => (
          <li>
            <a
              href={l.href}
              class={`px-4 py-2 text-sm font-medium tracking-wide transition-colors ${
                path === l.href
                  ? 'text-[var(--color-gold-400)]'
                  : 'text-[var(--color-cream-100)] hover:text-[var(--color-gold-300)]'
              }`}
            >
              {l.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/donate" class="ml-2 btn btn-primary !py-2 !px-5 !min-h-[40px] text-xs">
            Donate
          </a>
        </li>
      </ul>
    </nav>
  </div>

  {/* Mobile bottom nav */}
  <nav aria-label="Mobile" class="md:hidden fixed bottom-0 inset-x-0 bg-[var(--color-ink-950)]/95 backdrop-blur border-t border-[var(--color-ink-700)] z-50">
    <ul class="grid grid-cols-5">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class={`flex flex-col items-center justify-center py-3 text-[0.7rem] tracking-wide no-underline ${
              path === l.href ? 'text-[var(--color-gold-400)] font-semibold' : 'text-[var(--color-cream-200)]'
            }`}
            style="min-height: 56px;"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
